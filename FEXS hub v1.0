--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

--// GUI CREATION
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "MM2HelperUI"

-- OPEN BUTTON
local openBtn = Instance.new("TextButton", gui)
openBtn.Size = UDim2.new(0, 50, 0, 100)
openBtn.Position = UDim2.new(0, 0, 0.4, 0)
openBtn.Text = ">"
openBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
openBtn.TextColor3 = Color3.new(1,1,1)
openBtn.Active = true
openBtn.Draggable = true

-- MAIN FRAME
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 350, 0, 300)
main.Position = UDim2.new(-0.4, 0, 0.3, 0)
main.BackgroundColor3 = Color3.fromRGB(20,20,20)

-- DRAG
main.Active = true
main.Draggable = true

-- TABS
local tabs = {"Murderer","Sheriff","Visual"}
local tabFrames = {}

local tabHolder = Instance.new("Frame", main)
tabHolder.Size = UDim2.new(1,0,0,30)

local content = Instance.new("Frame", main)
content.Position = UDim2.new(0,0,0,30)
content.Size = UDim2.new(1,0,1,-30)

-- CREATE TABS
for i,v in pairs(tabs) do
	local btn = Instance.new("TextButton", tabHolder)
	btn.Size = UDim2.new(1/#tabs,0,1,0)
	btn.Position = UDim2.new((i-1)/#tabs,0,0,0)
	btn.Text = v
	btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
	btn.TextColor3 = Color3.new(1,1,1)

	local frame = Instance.new("Frame", content)
	frame.Size = UDim2.new(1,0,1,0)
	frame.Visible = false
	frame.BackgroundTransparency = 1
	
	tabFrames[v] = frame
	
	btn.MouseButton1Click:Connect(function()
		for _,f in pairs(tabFrames) do f.Visible = false end
		frame.Visible = true
	end)
end

tabFrames["Visual"].Visible = true

--// TOGGLE FUNCTION
function createToggle(parent, text, callback)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(0,200,0,40)
	btn.Text = text.." [OFF]"
	btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
	btn.TextColor3 = Color3.new(1,1,1)

	local state = false

	btn.MouseButton1Click:Connect(function()
		state = not state
		btn.Text = text.." ["..(state and "ON" or "OFF").."]"
		callback(state)
	end)

	return btn
end

--// ESP
local espEnabled = {
	Innocent = false,
	Murderer = false,
	Sheriff = false
}

function updateESP()
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Character then
			local char = plr.Character
			
			if char:FindFirstChild("Highlight") then
				char.Highlight:Destroy()
			end
			
			local highlight = Instance.new("Highlight", char)

			if espEnabled.Innocent then
				highlight.FillColor = Color3.fromRGB(0,255,0)
			end
			
			if plr.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then
				if espEnabled.Murderer then
					highlight.FillColor = Color3.fromRGB(255,0,0)
				end
			end
			
			if plr.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then
				if espEnabled.Sheriff then
					highlight.FillColor = Color3.fromRGB(0,0,255)
				end
			end
		end
	end
end

RunService.RenderStepped:Connect(updateESP)

--// VISUAL TAB
local visual = tabFrames["Visual"]

createToggle(visual, "Innocent ESP", function(v)
	espEnabled.Innocent = v
end).Position = UDim2.new(0,10,0,10)

createToggle(visual, "Murderer ESP", function(v)
	espEnabled.Murderer = v
end).Position = UDim2.new(0,10,0,60)

createToggle(visual, "Sheriff ESP", function(v)
	espEnabled.Sheriff = v
end).Position = UDim2.new(0,10,0,110)

-- POTATO MODE
createToggle(visual, "Potato Mode", function(v)
	for _,obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Texture") or obj:IsA("Decal") then
			obj:Destroy()
		end
	end
	
	game.Lighting.GlobalShadows = not v
	game.Lighting.FogEnd = v and 50 or 100000
end).Position = UDim2.new(0,10,0,160)

-- GLOSSY MODE
createToggle(visual, "Glossy Mode", function(v)
	for _,part in pairs(workspace:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Material = v and Enum.Material.Neon or Enum.Material.Plastic
		end
	end
end).Position = UDim2.new(0,10,0,210)

--// CAMERA LOCK
local locking = false
local target = nil

function getPlayerWithTool(toolName)
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			if plr.Backpack:FindFirstChild(toolName) or (plr.Character and plr.Character:FindFirstChild(toolName)) then
				return plr
			end
		end
	end
end

RunService.RenderStepped:Connect(function()
	if locking and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
		workspace.CurrentCamera.CFrame = CFrame.new(
			workspace.CurrentCamera.CFrame.Position,
			target.Character.HumanoidRootPart.Position
		)
	end
end)

-- ON SCREEN LOCK BUTTON
local lockBtn = Instance.new("TextButton", gui)
lockBtn.Size = UDim2.new(0,120,0,50)
lockBtn.Position = UDim2.new(0.5,-60,0.8,0)
lockBtn.Text = "LOCK"
lockBtn.BackgroundTransparency = 0.5
lockBtn.Visible = false
lockBtn.Active = true
lockBtn.Draggable = true

lockBtn.MouseButton1Click:Connect(function()
	locking = not locking
end)

-- MURDERER TAB
local murdererTab = tabFrames["Murderer"]

createToggle(murdererTab, "Lock On Sheriff", function(v)
	lockBtn.Visible = v
	target = getPlayerWithTool("Gun")
end).Position = UDim2.new(0,10,0,10)

-- SHERIFF TAB
local sheriffTab = tabFrames["Sheriff"]

createToggle(sheriffTab, "Lock On Murderer", function(v)
	lockBtn.Visible = v
	target = getPlayerWithTool("Knife")
end).Position = UDim2.new(0,10,0,10)

--// OPEN/CLOSE ANIMATION
local open = false

openBtn.MouseButton1Click:Connect(function()
	open = not open
	
	if open then
		main:TweenPosition(UDim2.new(0,10,0.3,0),"Out","Quad",0.3,true)
		openBtn.Text = "<"
	else
		main:TweenPosition(UDim2.new(-0.4,0,0.3,0),"Out","Quad",0.3,true)
		openBtn.Text = ">"
	end
end)
