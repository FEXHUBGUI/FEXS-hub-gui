-- ══════════════════════════════════════
--  Rain Hub v11.0
-- ══════════════════════════════════════
--  v1.0  — Shoot Murd, Lock, Fake Speed,
--           Gun TP, Player ESP
--  v2.0  — Auto Farm, Noclip, Coin tween,
--           Rainbow ESP, DescendantRemoving
--  v3.0  — Highlight parented to part,
--           Touched instant retarget
--  v4.0  — No-wait touch retarget
--  v5.0  — Slide menu, pill toggles,
--           badge indicators, PC+Mobile drag
--  v6.0  — Toggle button top-center,
--           menu centered, SelectionBox ESP,
--           cached coin table, no lag
--  v7.0  — Floating red Lock Murd cube btn
--  v8.0  — Menu pill only shows/hides float
--           btn, float btn does actual lock
--  v9.0  — 📌 pin buttons on toggle + float
--  v10.0 — ⚙️ Settings panel in menu corner:
--           • 10 preset color themes + custom
--           • Hub appearance color controls
--           • Player ESP color controls
--           • Coin ESP color controls
--           • Auto Farm speed slider
--           • Fake Speed value slider
--           • Performance: no animations,
--             no textures, no shadows,
--             low detail, FPS cap
--           • All settings save per-user
--             via writefile/readfile
--           • Reset to Default button
--  v11.0 — 🐛 Bug fix: settings no longer
--           break on load (fixed broken
--           boolean regex pattern in
--           loadSettings — missing concat
--           operator caused full script
--           parse failure, blank UI)
-- ══════════════════════════════════════
local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Lighting         = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer
local Camera      = workspace.CurrentCamera

-- ══════════════════════════════════════
--   SAVE / LOAD  (executor writefile)
-- ══════════════════════════════════════
local SAVE_FILE = "RainHub_Settings.json"

local DEFAULT_SETTINGS = {
	-- Hub theme
	hubAccent      = {r=60,  g=140, b=255},
	hubBg          = {r=8,   g=16,  b=38},
	hubHeader      = {r=13,  g=26,  b=65},
	-- Player ESP
	murdFill       = {r=200, g=20,  b=20},
	murdOutline    = {r=255, g=70,  b=70},
	sheriffFill    = {r=20,  g=70,  b=210},
	sheriffOutline = {r=70,  g=140, b=255},
	innocFill      = {r=110, g=30,  b=190},
	innocOutline   = {r=170, g=80,  b=255},
	-- Farm / Speed
	farmSpeed      = 0.18,   -- FARM_TWEEN_T
	fakeSpeed      = 100,    -- FAKE_SPEED
	-- Performance
	noAnimations   = false,
	noTextures     = false,
	noShadows      = false,
	lowDetail      = false,
	fpsCap         = 60,
}

local cfg = {}
for k,v in pairs(DEFAULT_SETTINGS) do cfg[k] = v end

local function deepCopy(t)
	local c = {}
	for k,v in pairs(t) do
		c[k] = (type(v)=="table") and deepCopy(v) or v
	end
	return c
end

local function saveSettings()
	if not writefile then return end
	pcall(function()
		local lines = {"{"}
		for k,v in pairs(cfg) do
			if type(v)=="table" then
				lines[#lines+1] = string.format('  "%s":{"r":%d,"g":%d,"b":%d},', k, v.r, v.g, v.b)
			elseif type(v)=="boolean" then
				lines[#lines+1] = string.format('  "%s":%s,', k, tostring(v))
			else
				lines[#lines+1] = string.format('  "%s":%s,', k, tostring(v))
			end
		end
		-- remove trailing comma from last entry
		if #lines > 1 then
			lines[#lines] = lines[#lines]:sub(1,-2)
		end
		lines[#lines+1] = "}"
		writefile(SAVE_FILE, table.concat(lines, "\n"))
	end)
end

local function loadSettings()
	if not readfile or not isfile then return end
	pcall(function()
		if not isfile(SAVE_FILE) then return end
		local raw = readfile(SAVE_FILE)
		-- simple JSON parse for our known keys
		for k,v in pairs(DEFAULT_SETTINGS) do
			if type(v) == "table" then
				local r = raw:match('"'..k..'":%s*{[^}]*"r":%s*(%d+)')
				local g = raw:match('"'..k..'":%s*{[^}]*"g":%s*(%d+)')
				local b = raw:match('"'..k..'":%s*{[^}]*"b":%s*(%d+)')
				if r and g and b then
					cfg[k] = {r=tonumber(r), g=tonumber(g), b=tonumber(b)}
				end
			elseif type(v) == "boolean" then
				-- FIXED v11.0: was missing .. before closing quote (k.'" instead of k..'"')
				local val = raw:match('"'..k..'":%s*(true|false)')
				if val then cfg[k] = (val=="true") end
			elseif type(v) == "number" then
				local val = raw:match('"'..k..'":%s*([%d%.]+)')
				if val then cfg[k] = tonumber(val) end
			end
		end
	end)
end

loadSettings()

-- helpers to get Color3 from cfg table
local function cfgC3(key)
	local t = cfg[key]
	return Color3.fromRGB(t.r, t.g, t.b)
end

-- live config references (updated by settings)
