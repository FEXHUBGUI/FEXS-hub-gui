--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "RainHubMM2"

-- SIDE BUTTON
local toggleBtn = Instance.new("TextButton", gui)
toggleBtn.Size = UDim2.new(0,30,0,70)
toggleBtn.Position = UDim2.new(0,0,0.4,0)
toggleBtn.Text = "≡"
toggleBtn.Font = Enum.Font.Arcade
toggleBtn.TextScaled = true
toggleBtn.BackgroundColor3 = Color3.fromRGB(0,120,255)
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.Draggable = true
Instance.new("UICorner", toggleBtn)

-- MAIN FRAME
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,300,0,260)
main.Position = UDim2.new(0.5,-150,0.5,-130)
main.BackgroundColor3 = Color3.fromRGB(10,15,25)
main.Visible = false
main.Active = true
main.Draggable = true
Instance.new("UICorner", main)

-- TITLE
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Rain Hub MM2"
title.Font = Enum.Font.Arcade
title.TextScaled = true
title.TextColor3 = Color3.fromRGB(0,170,255)
title.BackgroundTransparency = 1

-- TABS
local tabHolder = Instance.new("Frame", main)
tabHolder.Size = UDim2.new(1,0,0,25)
tabHolder.Position = UDim2.new(0,0,0,30)

local content = Instance.new("Frame", main)
content.Size = UDim2.new(1,0,1,-55)
content.Position = UDim2.new(0,0,0,55)

local tabs = {"Murderer","Sheriff","Visual"}
local tabFrames = {}

for i,name in pairs(tabs) do
	local btn = Instance.new("TextButton", tabHolder)
	btn.Size = UDim2.new(1/#tabs,0,1,0)
	btn.Position = UDim2.new((i-1)/#tabs,0,0,0)
	btn.Text = name
	btn.Font = Enum.Font.Arcade
	btn.TextScaled = true
	btn.BackgroundColor3 = Color3.fromRGB(20,25,40)
	btn.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", btn)

	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = Color3.fromRGB(0,150,255)
	stroke.Thickness = 2

	local frame = Instance.new("Frame", content)
	frame.Size = UDim2.new(1,0,1,0)
	frame.Visible = false

	tabFrames[name] = frame

	btn.MouseButton1Click:Connect(function()
		for _,f in pairs(tabFrames) do f.Visible = false end
		frame.Visible = true
	end)
end

tabFrames["Visual"].Visible = true

-- BUTTON CREATOR
function makeBtn(parent,text,y,color,callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.9,0,0,45)
	b.Position = UDim2.new(0.05,0,0,y)
	b.Text = text.." [OFF]"
	b.Font = Enum.Font.Arcade
	b.TextScaled = true
	b.BackgroundColor3 = Color3.fromRGB(15,15,25)
	b.TextColor3 = Color3.new(1,1,1)

	local stroke = Instance.new("UIStroke", b)
	stroke.Color = color
	stroke.Thickness = 2

	Instance.new("UICorner", b)

	local state = false

	b.MouseButton1Click:Connect(function()
		state = not state
		
		b:TweenSize(UDim2.new(0.88,0,0,42),"Out","Quad",0.08,true)
		task.wait(0.08)
		b:TweenSize(UDim2.new(0.9,0,0,45),"Out","Quad",0.08,true)

		b.Text = text.." ["..(state and "ON" or "OFF").."]"
		callback(state)
	end)
end

-- ESP
local espOn = false

RunService.RenderStepped:Connect(function()
	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			local char = p.Character

			if char:FindFirstChild("Highlight") then
				char.Highlight:Destroy()
			end

			if espOn then
				local h = Instance.new("Highlight", char)

				if p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then
					h.FillColor = Color3.fromRGB(255,0,0)
				elseif p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then
					h.FillColor = Color3.fromRGB(0,150,255)
				else
					h.FillColor = Color3.fromRGB(0,255,0)
				end
			end
		end
	end
end)

-- VISUAL TAB
makeBtn(tabFrames["Visual"],"ESP",10,Color3.fromRGB(0,150,255),function(v)
	espOn = v
end)

makeBtn(tabFrames["Visual"],"Potato Mode",60,Color3.fromRGB(150,150,150),function(v)
	Lighting.GlobalShadows = not v
	for _,d in pairs(workspace:GetDescendants()) do
		if d:IsA("Texture") or d:IsA("Decal") then
			d:Destroy()
		end
	end
end)

makeBtn(tabFrames["Visual"],"Glossy Shader",110,Color3.fromRGB(0,200,255),function(v)
	for _,p in pairs(workspace:GetDescendants()) do
		if p:IsA("BasePart") then
			p.Material = v and Enum.Material.SmoothPlastic or Enum.Material.Plastic
			p.Reflectance = v and 0.5 or 0
		end
	end
end)

-- LOCK BUTTONS

-- MURDERER
local murderBtn = Instance.new("TextButton", gui)
murderBtn.Size = UDim2.new(0,140,0,50)
murderBtn.Position = UDim2.new(0.35,0,0.8,0)
murderBtn.Visible = false
murderBtn.Text = "Lock Murderer"
murderBtn.Font = Enum.Font.Arcade
murderBtn.TextScaled = true
murderBtn.BackgroundColor3 = Color3.fromRGB(200,50,50)
murderBtn.TextColor3 = Color3.new(1,1,1)
murderBtn.Draggable = true
Instance.new("UICorner", murderBtn)

local mStroke = Instance.new("UIStroke", murderBtn)
mStroke.Color = Color3.fromRGB(0,150,255)
mStroke.Thickness = 2

-- SHERIFF
local sheriffBtn = Instance.new("TextButton", gui)
sheriffBtn.Size = UDim2.new(0,140,0,50)
sheriffBtn.Position = UDim2.new(0.55,0,0.8,0)
sheriffBtn.Visible = false
sheriffBtn.Text = "Lock Sheriff"
sheriffBtn.Font = Enum.Font.Arcade
sheriffBtn.TextScaled = true
sheriffBtn.BackgroundColor3 = Color3.fromRGB(0,120,255)
sheriffBtn.TextColor3 = Color3.new(1,1,1)
sheriffBtn.Draggable = true
Instance.new("UICorner", sheriffBtn)

local sStroke = Instance.new("UIStroke", sheriffBtn)
sStroke.Color = Color3.fromRGB(0,150,255)
sStroke.Thickness = 2

-- LOCK LOGIC
local murderLock = false
local sheriffLock = false

murderBtn.MouseButton1Click:Connect(function()
	murderLock = not murderLock
end)

sheriffBtn.MouseButton1Click:Connect(function()
	sheriffLock = not sheriffLock
end)

RunService.RenderStepped:Connect(function()
	local cam = workspace.CurrentCamera

	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then

			if murderLock then
				if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
					cam.CFrame = cam.CFrame:Lerp(
						CFrame.new(cam.CFrame.Position, p.Character.HumanoidRootPart.Position),
						0.2
					)
				end
			end

			if sheriffLock then
				if p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun") then
					cam.CFrame = cam.CFrame:Lerp(
						CFrame.new(cam.CFrame.Position, p.Character.HumanoidRootPart.Position),
						0.2
					)
				end
			end

		end
	end
end)

-- TAB BUTTONS
makeBtn(tabFrames["Murderer"],"Lock Sheriff Button",10,Color3.fromRGB(0,150,255),function(v)
	sheriffBtn.Visible = v
end)

makeBtn(tabFrames["Sheriff"],"Lock Murderer Button",10,Color3.fromRGB(255,50,50),function(v)
	murderBtn.Visible = v
end)

-- OPEN ANIMATION
toggleBtn.MouseButton1Click:Connect(function()
	main.Visible = not main.Visible
	
	if main.Visible then
		main.Size = UDim2.new(0,0,0,0)
		main:TweenSize(UDim2.new(0,300,0,260),"Out","Back",0.25,true)
	end
end)
