local toggleBtn = Instance.new("TextButton")
toggleBtn.Size             = UDim2.new(0, 120, 0, 32)
toggleBtn.Position         = UDim2.new(0.5, -60, 0, 8)
toggleBtn.BackgroundColor3 = Color3.fromRGB(10, 22, 55)
toggleBtn.BorderSizePixel  = 0
toggleBtn.Text             = "🌧️  Rain Hub"
toggleBtn.TextColor3       = Color3.fromRGB(160, 210, 255)
toggleBtn.TextSize         = 13
toggleBtn.Font             = Enum.Font.GothamBold
toggleBtn.AutoButtonColor  = false
toggleBtn.ZIndex           = 30
toggleBtn.Parent           = screenGui
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 10)

local toggleStroke = Instance.new("UIStroke")
toggleStroke.Color     = Color3.fromRGB(45, 110, 230)
toggleStroke.Thickness = 1.5
toggleStroke.Parent    = toggleBtn

-- bottom accent line on toggle button
local toggleAccent = Instance.new("Frame")
toggleAccent.Size             = UDim2.new(0.6, 0, 0, 2)
toggleAccent.Position         = UDim2.new(0.2, 0, 1, -2)
toggleAccent.BackgroundColor3 = Color3.fromRGB(60, 140, 255)
toggleAccent.BorderSizePixel  = 0
toggleAccent.ZIndex           = 31
toggleAccent.Parent           = toggleBtn
Instance.new("UICorner", toggleAccent).CornerRadius = UDim.new(1, 0)

-- pin icon on the right side of the toggle button
local togglePinBtn = Instance.new("TextButton")
togglePinBtn.Size             = UDim2.new(0, 20, 0, 20)
togglePinBtn.Position         = UDim2.new(1, 2, 0.5, -10)  -- just outside right edge
togglePinBtn.BackgroundColor3 = Color3.fromRGB(20, 40, 90)
togglePinBtn.BorderSizePixel  = 0
togglePinBtn.Text             = "📌"
togglePinBtn.TextSize         = 11
togglePinBtn.Font             = Enum.Font.GothamBold
togglePinBtn.AutoButtonColor  = false
togglePinBtn.ZIndex           = 32
togglePinBtn.Parent           = toggleBtn
Instance.new("UICorner", togglePinBtn).CornerRadius = UDim.new(1, 0)

local togglePinned = false

-- draggable but only when not pinned
local toggleDragging, toggleDragStart, toggleDragPos = false, nil, nil
toggleBtn.InputBegan:Connect(function(inp)
	if togglePinned then return end
	if inp.UserInputType == Enum.UserInputType.MouseButton1
	or inp.UserInputType == Enum.UserInputType.Touch then
		toggleDragging  = true
		toggleDragStart = inp.Position
		toggleDragPos   = toggleBtn.Position
		inp.Changed:Connect(function()
			if inp.UserInputState == Enum.UserInputState.End then
				toggleDragging = false
			end
		end)
	end
end)
UserInputService.InputChanged:Connect(function(inp)
	if not toggleDragging or togglePinned then return end
	if inp.UserInputType == Enum.UserInputType.MouseMovement
	or inp.UserInputType == Enum.UserInputType.Touch then
		local d = inp.Position - toggleDragStart
		toggleBtn.Position = UDim2.new(
			toggleDragPos.X.Scale, toggleDragPos.X.Offset + d.X,
			toggleDragPos.Y.Scale, toggleDragPos.Y.Offset + d.Y
		)
	end
end)

togglePinBtn.MouseButton1Click:Connect(function()
	togglePinned = not togglePinned
	if togglePinned then
		togglePinBtn.BackgroundColor3 = Color3.fromRGB(60, 200, 100)
		togglePinBtn.Text             = "🔒"
	else
		togglePinBtn.BackgroundColor3 = Color3.fromRGB(20, 40, 90)
		togglePinBtn.Text             = "📌"
	end
end)

