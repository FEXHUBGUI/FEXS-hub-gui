--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")
local SoundService = game:GetService("SoundService")

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "RainHubMM2"

-- BLUR (GLASS EFFECT)
local blur = Instance.new("BlurEffect", Lighting)
blur.Size = 0

-- SOUND
local clickSound = Instance.new("Sound", SoundService)
clickSound.SoundId = "rbxassetid://12221967"
clickSound.Volume = 0.2

-- SIDE BUTTON
local toggleBtn = Instance.new("TextButton", gui)
toggleBtn.Size = UDim2.new(0,32,0,75)
toggleBtn.Position = UDim2.new(0,0,0.4,0)
toggleBtn.Text = "≡"
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextScaled = true
toggleBtn.BackgroundColor3 = Color3.fromRGB(0,140,255)
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.Draggable = true
Instance.new("UICorner", toggleBtn)

-- MAIN (FROSTED GLASS PANEL)
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,330,0,280)
main.Position = UDim2.new(0.5,-165,0.5,-140)
main.BackgroundColor3 = Color3.fromRGB(18,22,35)
main.BackgroundTransparency = 0.25
main.Visible = false
main.Active = true
main.Draggable = true
Instance.new("UICorner", main)

-- INNER SHADOW (ULTRA SOFT LAYERING)
local shadow = Instance.new("Frame", main)
shadow.Size = UDim2.new(1,0,1,0)
shadow.BackgroundColor3 = Color3.fromRGB(0,0,0)
shadow.BackgroundTransparency = 0.88
shadow.ZIndex = main.ZIndex + 1
Instance.new("UICorner", shadow)

-- STATIC GLOW BORDER
local stroke = Instance.new("UIStroke", main)
stroke.Thickness = 2
stroke.Color = Color3.fromRGB(0,170,255)
stroke.Transparency = 0.25

-- TITLE
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,35)
title.Text = "Rain Hub MM2"
title.Font = Enum.Font.GothamBold
title.TextScaled = true
title.TextColor3 = Color3.fromRGB(200,230,255)
title.BackgroundTransparency = 1

-- HOVER SYSTEM
local function addHover(btn)
	local base = btn.BackgroundColor3
	btn.MouseEnter:Connect(function()
		btn.BackgroundColor3 = base:Lerp(Color3.new(1,1,1), 0.12)
	end)
	btn.MouseLeave:Connect(function()
		btn.BackgroundColor3 = base
	end)
end

-- TABS
local tabHolder = Instance.new("Frame", main)
tabHolder.Size = UDim2.new(1,0,0,30)
tabHolder.Position = UDim2.new(0,0,0,35)

local content = Instance.new("Frame", main)
content.Size = UDim2.new(1,0,1,-65)
content.Position = UDim2.new(0,0,0,65)

local tabs = {"Murderer","Sheriff","Visual"}
local tabFrames = {}

for i,name in pairs(tabs) do
	local btn = Instance.new("TextButton", tabHolder)
	btn.Size = UDim2.new(1/#tabs,0,1,0)
	btn.Position = UDim2.new((i-1)/#tabs,0,0,0)
	btn.Text = name
	btn.Font = Enum.Font.GothamBold
	btn.TextScaled = true
	btn.BackgroundColor3 = Color3.fromRGB(25,30,50)
	btn.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", btn)
	addHover(btn)

	local frame = Instance.new("Frame", content)
	frame.Size = UDim2.new(1,0,1,0)
	frame.Visible = false
	frame.BackgroundTransparency = 1

	tabFrames[name] = frame

	btn.MouseButton1Click:Connect(function()
		clickSound:Play()
		for _,f in pairs(tabFrames) do f.Visible = false end
		frame.Visible = true
	end)
end

tabFrames["Visual"].Visible = true

-- BUTTON FACTORY (UPGRADED STYLE)
function makeBtn(parent,text,y,color,callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.9,0,0,48)
	b.Position = UDim2.new(0.05,0,0,y)
	b.Text = text.." [OFF]"
	b.Font = Enum.Font.GothamBold
	b.TextScaled = true
	b.BackgroundColor3 = Color3.fromRGB(25,30,50)
	b.TextColor3 = Color3.new(1,1,1)

	local grad = Instance.new("UIGradient", b)
	grad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(0,140,255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0,200,255))
	}

	local stroke2 = Instance.new("UIStroke", b)
	stroke2.Color = color
	stroke2.Thickness = 2

	Instance.new("UICorner", b)
	addHover(b)

	local state = false

	b.MouseButton1Click:Connect(function()
		clickSound:Play()
		state = not state
		b.Text = text.." ["..(state and "ON" or "OFF").."]"
		callback(state)
	end)
end

-- VISUAL TAB (SAFE PLACEHOLDERS)
local espOn = false

RunService.RenderStepped:Connect(function()
	-- SAFE PLACEHOLDER (NO PLAYER TARGETING FEATURES)
end)

makeBtn(tabFrames["Visual"],"Visual Toggle (Placeholder)",10,Color3.fromRGB(0,200,255),function(v)
	espOn = v
end)

makeBtn(tabFrames["Visual"],"Potato Mode",65,Color3.fromRGB(150,150,150),function(v)
	Lighting.GlobalShadows = not v
end)

makeBtn(tabFrames["Visual"],"Glossy Shader",120,Color3.fromRGB(0,200,255),function(v)
	for _,p in pairs(workspace:GetDescendants()) do
		if p:IsA("BasePart") then
			p.Material = v and Enum.Material.SmoothPlastic or Enum.Material.Plastic
			p.Reflectance = v and 0.5 or 0
		end
	end
end)

