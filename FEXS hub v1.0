uiListLayout.SortOrder = Enum.SortOrder.LayoutOrder
uiListLayout.Padding = UDim.new(0, 5)
uiListLayout.Parent = resultsFrame

-- Function to update results
local function updateResults(query)
    for _, child in ipairs(resultsFrame:GetChildren()) do
        if child:IsA("TextLabel") then
            child:Destroy()
        end
    end
    query = query:lower()
    local count = 0
    for cleanName, data in pairs(values) do
        if cleanName:find(query) then
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 0, 30)
            label.BackgroundTransparency = 1
            label.Text = data.name .. ": " .. data.value
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.TextSize = 16
            label.Font = Enum.Font.Gotham
            label.Parent = resultsFrame
            count = count + 1
        end
    end
    resultsFrame.CanvasSize = UDim2.new(0, 0, 0, count * 35)
end

searchBox.FocusLost:Connect(function(enter)
    if enter then
        updateResults(searchBox.Text)
    end
end)

