--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

--// GUI SETUP
local gui = Instance.new("ScreenGui")
gui.Name = "DebugPanel"
gui.ResetOnSpawn = false
gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 160)
frame.Position = UDim2.new(0.05, 0, 0.3, 0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local function makeButton(text, posY)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 40)
    btn.Position = UDim2.new(0, 5, 0, posY)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Text = text
    btn.Parent = frame
    return btn
end

local speedBtn = makeButton("Speed Toggle", 10)
local espBtn = makeButton("Highlight Debug", 60)

--// SPEED + SPIN SYSTEM
local speedEnabled = false
local spinConn

local function startSpin()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")

    hum.WalkSpeed = 100

    spinConn = RunService.RenderStepped:Connect(function()
        if speedEnabled and hrp then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(25), 0)
        end
    end)
end

local function stopSpin()
    if spinConn then
        spinConn:Disconnect()
        spinConn = nil
    end

    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = 16
    end
end

speedBtn.MouseButton1Click:Connect(function()
    speedEnabled = not speedEnabled
    if speedEnabled then
        startSpin()
        speedBtn.Text = "Speed: ON"
    else
        stopSpin()
        speedBtn.Text = "Speed: OFF"
    end
end)

--// HIGHLIGHT SYSTEM (DEBUG ONLY)
local highlightEnabled = false
local highlights = {}

local function getColor(plr)
    if not plr.Character then return Color3.fromRGB(170,0,255) end

    local hasGun = plr.Character:FindFirstChild("Gun") or (plr.Backpack and plr.Backpack:FindFirstChild("Gun"))
    local hasKnife = plr.Character:FindFirstChild("Knife") or (plr.Backpack and plr.Backpack:FindFirstChild("Knife"))

    if hasGun then
        return Color3.fromRGB(0,170,255) -- blue
    elseif hasKnife then
        return Color3.fromRGB(255,0,0) -- red
    else
        return Color3.fromRGB(170,0,255) -- purple
    end
end

local function applyHighlight(plr)
    if plr == LocalPlayer then return end
    if not plr.Character then return end

    local char = plr.Character

    if not highlights[plr] then
        local h = Instance.new("Highlight")
        h.Parent = char
        highlights[plr] = h
    end

    highlights[plr].FillColor = getColor(plr)
    highlights[plr].OutlineColor = Color3.fromRGB(0,0,0)
end

local function clearHighlights()
    for _,h in pairs(highlights) do
        if h then h:Destroy() end
    end
    highlights = {}
end

local function updateLoop()
    for _,plr in pairs(Players:GetPlayers()) do
        applyHighlight(plr)
    end
end

espBtn.MouseButton1Click:Connect(function()
    highlightEnabled = not highlightEnabled

    if highlightEnabled then
        espBtn.Text = "Highlight: ON"

        task.spawn(function()
            while highlightEnabled do
                updateLoop()
                task.wait(0.5)
            end
        end)
    else
        espBtn.Text = "Highlight: OFF"
        clearHighlights()
    end
end)

--// AUTO UPDATE ON TOOL CHANGE
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        if highlightEnabled then
            applyHighlight(plr)
        end
    end)
end)
