-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- ══════════════════════════════════════
--           CONFIGURATION
-- ══════════════════════════════════════
local SHERIFF_TOOL = "Gun"
local MURD_TOOL    = "Knife"
local FAKE_SPEED   = 100
local SPIN_SPEED   = 20 -- degrees per frame

-- ══════════════════════════════════════
--              STATE
-- ══════════════════════════════════════
local lockedTarget    = nil
local fakeSpeedOn     = false
local espHighlights   = {}

-- ══════════════════════════════════════
--                GUI
-- ══════════════════════════════════════
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DebugPanel"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = LocalPlayer.PlayerGui

-- Main frame
local frame = Instance.new("Frame")
frame.Name = "MainFrame"
frame.Size = UDim2.new(0, 220, 0, 210)
frame.Position = UDim2.new(0.5, -110, 0.5, -105)
frame.BackgroundColor3 = Color3.fromRGB(18, 18, 28)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

-- Corner
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = frame

-- Stroke
local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(120, 80, 220)
stroke.Thickness = 2
stroke.Parent = frame

-- Title bar
local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 36)
titleBar.BackgroundColor3 = Color3.fromRGB(30, 20, 50)
titleBar.BorderSizePixel = 0
titleBar.Parent = frame

local titleCorner = Instance.new("UICorner")
titleCorner.CornerRadius = UDim.new(0, 12)
titleCorner.Parent = titleBar

-- Fix bottom corners of title bar
local titleFix = Instance.new("Frame")
titleFix.Size = UDim2.new(1, 0, 0.5, 0)
titleFix.Position = UDim2.new(0, 0, 0.5, 0)
titleFix.BackgroundColor3 = Color3.fromRGB(30, 20, 50)
titleFix.BorderSizePixel = 0
titleFix.Parent = titleBar

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 1, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "🔧 Debug Panel"
titleLabel.TextColor3 = Color3.fromRGB(200, 170, 255)
titleLabel.TextSize = 15
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = titleBar

-- Status label
local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -16, 0, 20)
statusLabel.Position = UDim2.new(0, 8, 0, 40)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Status: Idle"
statusLabel.TextColor3 = Color3.fromRGB(160, 160, 180)
statusLabel.TextSize = 12
statusLabel.Font = Enum.Font.Gotham
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Parent = frame

-- Helper: create button
local function makeButton(text, posY, color)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -20, 0, 42)
	btn.Position = UDim2.new(0, 10, 0, posY)
	btn.BackgroundColor3 = color
	btn.BorderSizePixel = 0
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 13
	btn.Font = Enum.Font.GothamBold
	btn.AutoButtonColor = false
	btn.Parent = frame

	local bc = Instance.new("UICorner")
	bc.CornerRadius = UDim.new(0, 8)
	bc.Parent = btn

	local bs = Instance.new("UIStroke")
	bs.Color = Color3.fromRGB(255, 255, 255)
	bs.Transparency = 0.85
	bs.Thickness = 1
	bs.Parent = btn

	-- Hover effect
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = color:Lerp(Color3.new(1,1,1), 0.15)}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = color}):Play()
	end)

	return btn
end

local lockSheriffBtn = makeButton("🔵  Lock Sheriff", 66,  Color3.fromRGB(40, 100, 200))
local lockMurdBtn    = makeButton("🔴  Lock Murd",    116, Color3.fromRGB(180, 40, 40))
local fakeSpeedBtn   = makeButton("⚡  Fake Speed Glitch [needs tool]", 166, Color3.fromRGB(80, 40, 160))

-- ══════════════════════════════════════
--           UTILITY FUNCTIONS
-- ══════════════════════════════════════
local function getCharacter(player)
	return player and player.Character
end

local function getRootPart(player)
	local char = getCharacter(player)
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function hasTool(player, toolName)
	local char = getCharacter(player)
	if char and char:FindFirstChild(toolName) then return true end
	local bp = player.Backpack
	if bp and bp:FindFirstChild(toolName) then return true end
	return false
end

local function hasAnyToolEquipped(player)
	local char = getCharacter(player)
	if not char then return false end
	for _, v in ipairs(char:GetChildren()) do
		if v:IsA("Tool") then return true end
	end
	return false
end

local function findPlayerWithTool(toolName)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and hasTool(p, toolName) then
			return p
		end
	end
	return nil
end

local function setStatus(text, color)
	statusLabel.Text = "Status: " .. text
	statusLabel.TextColor3 = color or Color3.fromRGB(160, 160, 180)
end

-- ══════════════════════════════════════
--              ESP SYSTEM
-- ══════════════════════════════════════
local function removeESP(player)
	if espHighlights[player] then
		espHighlights[player]:Destroy()
		espHighlights[player] = nil
	end
end

local function applyESP(player, fillColor, outlineColor)
	local char = getCharacter(player)
	if not char then return end

	-- Remove old if exists
	if espHighlights[player] then
		espHighlights[player]:Destroy()
	end

	local highlight = Instance.new("SelectionBox")
	highlight.Adornee = char
	highlight.Color3 = outlineColor or fillColor
	highlight.LineThickness = 0.08
	highlight.SurfaceTransparency = 0.5
	highlight.SurfaceColor3 = fillColor
	highlight.Parent = Camera

	espHighlights[player] = highlight
end

local function updateESP()
	-- Clean up for players who left
	for player, _ in pairs(espHighlights) do
		if not Players:FindFirstChild(player.Name) then
			removeESP(player)
		end
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end

		local char = getCharacter(player)
		if not char then
			removeESP(player)
			continue
		end

		if hasTool(player, MURD_TOOL) then
			-- Murderer: Red
			applyESP(player, Color3.fromRGB(220, 40, 40), Color3.fromRGB(255, 80, 80))
		elseif hasTool(player, SHERIFF_TOOL) then
			-- Sheriff: Blue
			applyESP(player, Color3.fromRGB(40, 80, 220), Color3.fromRGB(80, 140, 255))
		else
			-- Innocent: Purple
			applyESP(player, Color3.fromRGB(140, 60, 220), Color3.fromRGB(180, 100, 255))
		end

		-- Update adornee in case character respawned
		if espHighlights[player] then
			espHighlights[player].Adornee = char
		end
	end
end

-- ══════════════════════════════════════
--           LOCK-ON SYSTEM
-- ══════════════════════════════════════
local function lockOnto(toolName, label)
	local target = findPlayerWithTool(toolName)
	if target then
		lockedTarget = target
		setStatus("Locked → " .. target.Name, Color3.fromRGB(100, 255, 150))
		print("[Debug] Locked onto: " .. target.Name .. " (" .. label .. ")")
	else
		lockedTarget = nil
		setStatus("No " .. label .. " found", Color3.fromRGB(255, 120, 80))
	end
end

lockSheriffBtn.MouseButton1Click:Connect(function()
	lockOnto(SHERIFF_TOOL, "Sheriff")
end)

lockMurdBtn.MouseButton1Click:Connect(function()
	lockOnto(MURD_TOOL, "Murd")
end)

-- ══════════════════════════════════════
--         FAKE SPEED / SPIN
-- ══════════════════════════════════════
local spinAngle = 0

fakeSpeedBtn.MouseButton1Click:Connect(function()
	fakeSpeedOn = not fakeSpeedOn
	if fakeSpeedOn then
		fakeSpeedBtn.BackgroundColor3 = Color3.fromRGB(130, 60, 255)
		fakeSpeedBtn.Text = "⚡  Fake Speed [ON]"
		setStatus("Fake Speed ON", Color3.fromRGB(180, 100, 255))
	else
		fakeSpeedBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 160)
		fakeSpeedBtn.Text = "⚡  Fake Speed Glitch [needs tool]"
		setStatus("Fake Speed OFF", Color3.fromRGB(160, 160, 180))
		-- Reset speed
		local char = getCharacter(LocalPlayer)
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed = 16 end
	end
end)

-- ══════════════════════════════════════
--            MAIN LOOP
-- ══════════════════════════════════════
RunService.Heartbeat:Connect(function(dt)
	-- ESP update
	updateESP()

	-- Auto-update lock target if they lose their tool
	if lockedTarget then
		-- Check if target still has the tool they were locked for
		local stillValid = hasTool(lockedTarget, SHERIFF_TOOL) or hasTool(lockedTarget, MURD_TOOL)
		if not stillValid or not getCharacter(lockedTarget) then
			lockedTarget = nil
			setStatus("Target lost tool", Color3.fromRGB(255, 180, 60))
		end
	end

	-- Fake Speed + Spin
	if fakeSpeedOn then
		local char = getCharacter(LocalPlayer)
		if not char then return end

		local hum  = char:FindFirstChildOfClass("Humanoid")
		local root = char:FindFirstChild("HumanoidRootPart")

		if hasAnyToolEquipped(LocalPlayer) then
			if hum then hum.WalkSpeed = FAKE_SPEED end

			if root then
				spinAngle = (spinAngle + SPIN_SPEED) % 360
				root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(SPIN_SPEED), 0)
			end
		else
			-- No tool equipped: reset speed, pause spin
			if hum then hum.WalkSpeed = 16 end
		end
	end
end)

-- Cleanup ESP on player leaving
Players.PlayerRemoving:Connect(function(player)
	removeESP(player)
	if lockedTarget == player then
		lockedTarget = nil
		setStatus("Target left", Color3.fromRGB(255, 180, 60))
	end
end)

print("[Debug Panel] Loaded successfully.")
