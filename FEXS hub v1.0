--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

--// SETTINGS SAVE
local settings = {
	ESP = false,
	Potato = false,
	Glossy = false
}

pcall(function()
	local saved = game:GetService("HttpService"):JSONDecode(readfile("mm2ui_settings.json"))
	settings = saved
end)

function saveSettings()
	pcall(function()
		writefile("mm2ui_settings.json", game:GetService("HttpService"):JSONEncode(settings))
	end)
end

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "BlueUI"

-- SIDE BUTTON
local toggleBtn = Instance.new("TextButton", gui)
toggleBtn.Size = UDim2.new(0, 35, 0, 80)
toggleBtn.Position = UDim2.new(0, 0, 0.4, 0)
toggleBtn.Text = "≡"
toggleBtn.BackgroundColor3 = Color3.fromRGB(0,120,255)
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.Draggable = true

-- MAIN FRAME
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 320, 0, 280)
main.Position = UDim2.new(-1, 0, 0.3, 0)
main.BackgroundColor3 = Color3.fromRGB(15,15,25)
main.Active = true
main.Draggable = true

-- TITLE
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Blue Panel"
title.TextColor3 = Color3.fromRGB(0,170,255)
title.BackgroundTransparency = 1

-- CLOSE BUTTON
local close = Instance.new("TextButton", main)
close.Size = UDim2.new(0, 25, 0, 25)
close.Position = UDim2.new(1,-30,0,5)
close.Text = "X"
close.BackgroundColor3 = Color3.fromRGB(0,120,255)

-- CONTENT
local container = Instance.new("Frame", main)
container.Position = UDim2.new(0,0,0,35)
container.Size = UDim2.new(1,0,1,-35)
container.BackgroundTransparency = 1

-- BUTTON CREATOR
function createButton(text, y, callback)
	local btn = Instance.new("TextButton", container)
	btn.Size = UDim2.new(0,280,0,40)
	btn.Position = UDim2.new(0,20,0,y)
	btn.BackgroundColor3 = Color3.fromRGB(25,25,40)
	btn.TextColor3 = Color3.new(1,1,1)

	local function update()
		btn.Text = text.." ["..(settings[text] and "ON" or "OFF").."]"
	end

	update()

	btn.MouseButton1Click:Connect(function()
		settings[text] = not settings[text]
		update()
		saveSettings()
		callback(settings[text])
	end)
end

-- ESP SYSTEM
function updateESP()
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Character then
			local char = plr.Character

			if char:FindFirstChild("Highlight") then
				char.Highlight:Destroy()
			end

			if settings.ESP then
				local h = Instance.new("Highlight", char)

				if plr.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then
					h.FillColor = Color3.fromRGB(255,0,0)
				elseif plr.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then
					h.FillColor = Color3.fromRGB(0,100,255)
				else
					h.FillColor = Color3.fromRGB(0,255,0)
				end
			end
		end
	end
end

RunService.RenderStepped:Connect(updateESP)

-- POTATO MODE
function applyPotato(v)
	for _,obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Texture") or obj:IsA("Decal") then
			obj:Destroy()
		end
	end
	game.Lighting.GlobalShadows = not v
end

-- GLOSSY MODE
function applyGlossy(v)
	for _,p in pairs(workspace:GetDescendants()) do
		if p:IsA("BasePart") then
			p.Material = v and Enum.Material.Neon or Enum.Material.Plastic
		end
	end
end

-- BUTTONS
createButton("ESP", 10, function(v) end)
createButton("Potato", 60, applyPotato)
createButton("Glossy", 110, applyGlossy)

-- APPLY SAVED STATES
applyPotato(settings.Potato)
applyGlossy(settings.Glossy)

-- OPEN/CLOSE
local open = false

toggleBtn.MouseButton1Click:Connect(function()
	open = not open
	if open then
		main:TweenPosition(UDim2.new(0,10,0.3,0),"Out","Quad",0.25,true)
	else
		main:TweenPosition(UDim2.new(-1,0,0.3,0),"Out","Quad",0.25,true)
	end
end)

close.MouseButton1Click:Connect(function()
	open = false
	main:TweenPosition(UDim2.new(-1,0,0.3,0),"Out","Quad",0.25,true)
end)
