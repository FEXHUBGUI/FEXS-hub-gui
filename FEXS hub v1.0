-- MM2 VALUE CHECKER Script
-- Place this in a LocalScript in StarterPlayerScripts or use an exploit to run it.

local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "MM2ValueChecker"
gui.Parent = player:WaitForChild("PlayerGui")
gui.ResetOnSpawn = false

-- Values table
local values = {}
local categories = {"ancient", "unique", "godly", "vintage", "legendary", "rare", "uncommon", "common", "pets", "misc"}

-- Function to load values from website
local function loadValues()
    for _, cat in ipairs(categories) do
        local url = "https://mm2values.com/?p=" .. cat
        local success, response = pcall(function()
            return HttpService:GetAsync(url)
        end)
        if success then
            for name, valStr in string.gmatch(response, "%*%*(.-)%*%* Value: ([%d,]+)") do
                local cleanName = name:gsub("'", ""):lower()  -- Clean name for matching
                local value = tonumber(valStr:gsub(",", ""))
                if value then
                    values[cleanName] = {name = name, value = value}
                end
            end
        else
            warn("Failed to fetch " .. cat .. ": " .. response)
        end
    end
end

loadValues()

