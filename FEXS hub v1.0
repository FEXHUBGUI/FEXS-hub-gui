        local removeBtn = Instance.new("TextButton")
        removeBtn.Size = UDim2.new(0.2, 0, 1, 0)
        removeBtn.Position = UDim2.new(0.8, 0, 0, 0)
        removeBtn.BackgroundTransparency = 1
        removeBtn.Text = "X"
        removeBtn.TextColor3 = Color3.fromRGB(255, 0, 0)
        removeBtn.Parent = itemLabel
        removeBtn.MouseButton1Click:Connect(function()
            for i, v in ipairs(theirItems) do
                if v == data.value then
                    table.remove(theirItems, i)
                    break
                end
            end
            itemLabel:Destroy()
            updateTheirTotal()
            theirList.CanvasSize = UDim2.new(0, 0, 0, #theirList:GetChildren() * 35 - 35)
        end)
        
        theirList.CanvasSize = UDim2.new(0, 0, 0, (#theirList:GetChildren() - 1) * 35)
        updateTheirTotal()
        theirInput.Text = ""
    else
        StarterGui:SetCore("SendNotification", {Title = "Error", Text = "Item not found!", Duration = 3})
    end
end)

-- Calculate
calcBtn.MouseButton1Click:Connect(function()
    local yourSum = updateYourTotal()
    local theirSum = updateTheirTotal()
    local message
    if yourSum < theirSum then
        message = "You are winning! (Your offer: " .. yourSum .. ", Their: " .. theirSum .. ")"
    elseif yourSum > theirSum then
        message = "You are losing! (Your offer: " .. yourSum .. ", Their: " .. theirSum .. ")"
    else
        message = "It's fair! (Both: " .. yourSum .. ")"
    end
    StarterGui:SetCore("SendNotification", {Title = "Trade Result", Text = message, Duration = 5})
end)

