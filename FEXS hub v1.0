-- ══════════════════════════════════════
--   MENU OPEN / CLOSE
-- ══════════════════════════════════════
local menuOpen = false

local function openMenu()
	menuOpen          = true
	menuPanel.Visible = true
	menuPanel.Size    = UDim2.new(0, MENU_W, 0, 0)
	tw(menuPanel, {Size = UDim2.new(0, MENU_W, 0, MENU_H)}, easeOut)
	tw(toggleAccent, {BackgroundColor3 = Color3.fromRGB(80, 210, 120)}, fastTw)
	tw(toggleBtn,    {BackgroundColor3 = Color3.fromRGB(14, 32, 75)},   fastTw)
end

local function closeMenu()
	menuOpen = false
	tw(menuPanel, {Size = UDim2.new(0, MENU_W, 0, 0)}, easeIn)
	tw(toggleAccent, {BackgroundColor3 = Color3.fromRGB(60, 140, 255)}, fastTw)
	tw(toggleBtn,    {BackgroundColor3 = Color3.fromRGB(10, 22, 55)},   fastTw)
	task.delay(0.28, function()
		if not menuOpen then menuPanel.Visible = false end
	end)
end

toggleBtn.MouseButton1Click:Connect(function()
	if menuOpen then closeMenu() else openMenu() end
end)
closeBtn.MouseButton1Click:Connect(closeMenu)

-- ══════════════════════════════════════
--   FLOATING BADGE INDICATORS
-- ══════════════════════════════════════
local badges        = {}
local BADGE_W       = 132
local BADGE_H       = 30
local BADGE_START_Y = 50   -- just below the toggle button
local BADGE_GAP     = 36

local function reStackBadges()
	local i = 0
	for _, b in pairs(badges) do
		tw(b, {Position = UDim2.new(0.5, -(BADGE_W/2), 0, BADGE_START_Y + i * BADGE_GAP)}, fastTw)
		i += 1
	end
end

local function makeBadge(key, label, color)
	if badges[key] then return end
	local count = 0
	for _ in pairs(badges) do count += 1 end
	local yPos = BADGE_START_Y + count * BADGE_GAP

	local badge = Instance.new("Frame")
	badge.Size             = UDim2.new(0, BADGE_W, 0, BADGE_H)
	badge.Position         = UDim2.new(0.5, -(BADGE_W/2), 0, yPos - 20)
	badge.BackgroundColor3 = color
	badge.BackgroundTransparency = 1
	badge.BorderSizePixel  = 0
	badge.ZIndex           = 10
	badge.Parent           = screenGui
	Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 8)

	local dot = Instance.new("Frame")
	dot.Size             = UDim2.new(0, 7, 0, 7)
	dot.Position         = UDim2.new(0, 9, 0.5, -3)
	dot.BackgroundColor3 = Color3.new(1, 1, 1)
	dot.BackgroundTransparency = 0.3
	dot.BorderSizePixel  = 0
	dot.ZIndex           = 11
	dot.Parent           = badge
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local lbl = Instance.new("TextLabel")
	lbl.Size                = UDim2.new(1, -24, 1, 0)
	lbl.Position            = UDim2.new(0, 22, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text                = label
	lbl.TextColor3          = Color3.new(1, 1, 1)
	lbl.TextSize            = 10
	lbl.Font                = Enum.Font.GothamBold
	lbl.TextXAlignment      = Enum.TextXAlignment.Left
	lbl.TextTruncate        = Enum.TextTruncate.AtEnd
	lbl.ZIndex              = 11
	lbl.Name                = "BadgeLabel"
	lbl.Parent              = badge

	badges[key] = badge
	-- fade + slide in
	tw(badge, {BackgroundTransparency = 0, Position = UDim2.new(0.5, -(BADGE_W/2), 0, yPos)}, easeOut)
end

local function removeBadge(key)
	local badge = badges[key]
	if not badge then return end
	badges[key] = nil
	tw(badge, {BackgroundTransparency = 1, Position = UDim2.new(0.5, -(BADGE_W/2), 0, badge.Position.Y.Offset - 16)}, easeIn)
	task.delay(0.3, function() badge:Destroy() end)
	task.delay(0.05, reStackBadges)
end

local function setBadgeLabel(key, text)
	local b = badges[key]
	if not b then return end
	local l = b:FindFirstChild("BadgeLabel")
	if l then l.Text = text end
end

-- ══════════════════════════════════════
--   MENU TOGGLE ROW BUILDER
-- ══════════════════════════════════════
local rowOrder = 0
local COL_ON   = Color3.fromRGB(40, 200, 100)
local COL_OFF  = Color3.fromRGB(55, 60, 82)

local function makeToggleRow(icon, labelText, hintText, onToggle)
	rowOrder += 1

	local row = Instance.new("Frame")
	row.Size             = UDim2.new(1, 0, 0, 56)
	row.BackgroundColor3 = Color3.fromRGB(13, 26, 62)
	row.BorderSizePixel  = 0
	row.LayoutOrder      = rowOrder
	row.ZIndex           = 17
	row.Parent           = menuScroll
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

	local rs = Instance.new("UIStroke")
	rs.Color = Color3.fromRGB(28, 55, 130); rs.Thickness = 1
	rs.Transparency = 0.4; rs.Parent = row

	local iLbl = Instance.new("TextLabel")
	iLbl.Size = UDim2.new(0, 28, 0, 28); iLbl.Position = UDim2.new(0, 10, 0.5, -14)
	iLbl.BackgroundTransparency = 1; iLbl.Text = icon
	iLbl.TextSize = 18; iLbl.Font = Enum.Font.GothamBold
	iLbl.ZIndex = 18; iLbl.Parent = row

	local nLbl = Instance.new("TextLabel")
	nLbl.Size = UDim2.new(1, -90, 0, 20); nLbl.Position = UDim2.new(0, 44, 0, 10)
	nLbl.BackgroundTransparency = 1; nLbl.Text = labelText
	nLbl.TextColor3 = Color3.fromRGB(210, 225, 255)
	nLbl.TextSize = 13; nLbl.Font = Enum.Font.GothamBold
	nLbl.TextXAlignment = Enum.TextXAlignment.Left
	nLbl.ZIndex = 18; nLbl.Parent = row

	local hLbl = Instance.new("TextLabel")
	hLbl.Size = UDim2.new(1, -90, 0, 16); hLbl.Position = UDim2.new(0, 44, 0, 30)
	hLbl.BackgroundTransparency = 1; hLbl.Text = hintText
	hLbl.TextColor3 = Color3.fromRGB(90, 120, 178)
	hLbl.TextSize = 10; hLbl.Font = Enum.Font.Gotham
	hLbl.TextXAlignment = Enum.TextXAlignment.Left
	hLbl.ZIndex = 18; hLbl.Name = "HintLabel"; hLbl.Parent = row

	local pillBg = Instance.new("Frame")
	pillBg.Size = UDim2.new(0, 44, 0, 24); pillBg.Position = UDim2.new(1, -52, 0.5, -12)
	pillBg.BackgroundColor3 = COL_OFF; pillBg.BorderSizePixel = 0
	pillBg.ZIndex = 18; pillBg.Parent = row
	Instance.new("UICorner", pillBg).CornerRadius = UDim.new(1, 0)

	local pillKnob = Instance.new("Frame")
	pillKnob.Size = UDim2.new(0, 18, 0, 18); pillKnob.Position = UDim2.new(0, 3, 0.5, -9)
	pillKnob.BackgroundColor3 = Color3.new(1, 1, 1); pillKnob.BorderSizePixel = 0
	pillKnob.ZIndex = 19; pillKnob.Parent = pillBg
	Instance.new("UICorner", pillKnob).CornerRadius = UDim.new(1, 0)

	local isOn = false

	local rowBtn = Instance.new("TextButton")
	rowBtn.Size = UDim2.new(1, 0, 1, 0); rowBtn.BackgroundTransparency = 1
	rowBtn.Text = ""; rowBtn.ZIndex = 20; rowBtn.Parent = row

	local function setState(state)
		isOn = state
		if isOn then
			tw(pillBg,   {BackgroundColor3 = COL_ON},             fastTw)
			tw(pillKnob, {Position = UDim2.new(0, 23, 0.5, -9)}, fastTw)
		else
			tw(pillBg,   {BackgroundColor3 = COL_OFF},            fastTw)
			tw(pillKnob, {Position = UDim2.new(0, 3,  0.5, -9)}, fastTw)
		end
		onToggle(isOn, hLbl)
	end

	rowBtn.MouseButton1Click:Connect(function() setState(not isOn) end)
	return setState
end

-- ══════════════════════════════════════
--   UTILITY
-- ══════════════════════════════════════
local function getChar(p)  return p and p.Character end

local function hasTool(player, toolName)
	local c = getChar(player)
	if c and c:FindFirstChild(toolName) then return true end
	local bp = player:FindFirstChild("Backpack")
	return bp and bp:FindFirstChild(toolName) ~= nil
end

local function hasAnyTool(player)
	local c = getChar(player)
	if not c then return false end
	for _, v in ipairs(c:GetChildren()) do
		if v:IsA("Tool") then return true end
	end
	return false
end

local function findWithTool(toolName)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and hasTool(p, toolName) then return p end
	end
	return nil
end

-- ══════════════════════════════════════
--   NOCLIP
-- ══════════════════════════════════════
local function enableNoclip()
	if noclipConn then return end
	noclipConn = RunService.Stepped:Connect(function()
		local c = getChar(LocalPlayer)
		if not c then return end
		for _, p in ipairs(c:GetDescendants()) do
			if p:IsA("BasePart") then p.CanCollide = false end
		end
	end)
end

local function disableNoclip()
	if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
	local c = getChar(LocalPlayer)
	if c then
		for _, p in ipairs(c:GetDescendants()) do
			if p:IsA("BasePart") then p.CanCollide = true end
		end
	end
end

-- ══════════════════════════════════════
--   COIN ESP — SelectionBox
--   SelectionBox with SurfaceTransparency=1
--   renders its colored outline THROUGH
--   all geometry regardless of depth.
--   This is the only Roblox API that truly
--   guarantees through-wall visibility
--   without engine-side culling.
-- ══════════════════════════════════════
local function removeCoinESP(part)
	local d = coinEspData[part]
	if not d then return end
	if d.box      then pcall(function() d.box:Destroy()           end) end
	if d.touchConn then pcall(function() d.touchConn:Disconnect() end) end
	if part and part.Parent then
		pcall(function() part.Transparency = coinOrigTrans[part] or 0 end)
	end
	coinOrigTrans[part] = nil
	coinEspData[part]   = nil
end

local function applyCoinESP(part, rainbowColor)
	if not part or not part.Parent then return end
	local d = coinEspData[part]

	if not d then
		coinOrigTrans[part] = part.Transparency
		part.Transparency   = 0.5

		local touchConn
		touchConn = part.Touched:Connect(function(hit)
			local c = getChar(LocalPlayer)
			if not c or not hit:IsDescendantOf(c) then return end
			if not farmActive then return end
			touchConn:Disconnect()
			farmCurrentCoin = nil
			farmTweening    = false
			if farmTweenObj then farmTweenObj:Cancel(); farmTweenObj = nil end
		end)

		-- SelectionBox: SurfaceTransparency=1 hides faces, LineThickness gives
		-- a bright colored wire outline that renders through ALL walls
		local box = Instance.new("SelectionBox")
		box.LineThickness         = 0.06
		box.SurfaceTransparency   = 1        -- faces invisible, outline only
		box.SurfaceColor3         = rainbowColor
		box.Color3                = rainbowColor
		box.Adornee               = part
		box.Parent                = Camera   -- parent to Camera so it always renders

		d = { box = box, touchConn = touchConn }
		coinEspData[part] = d
	end

	-- update rainbow color every frame
	pcall(function() part.Color = rainbowColor end)
	if d.box then
		d.box.Color3        = rainbowColor
		d.box.SurfaceColor3 = rainbowColor
	end
end

-- ── COIN CACHE: kept live with events, NO per-frame scan ──
local function addCoinToCache(obj)
	if obj.Name == COIN_NAME and obj:IsA("BasePart") then
		coinCache[obj] = true
	end
end

local function removeCoinFromCache(obj)
	if obj.Name == COIN_NAME and obj:IsA("BasePart") then
		coinCache[obj] = nil
		removeCoinESP(obj)
		if farmActive and farmCurrentCoin == obj then
			farmCurrentCoin = nil
			farmTweening    = false
			if farmTweenObj then farmTweenObj:Cancel(); farmTweenObj = nil end
		end
	end
end

-- seed cache with anything already in workspace
for _, obj in ipairs(workspace:GetDescendants()) do
	addCoinToCache(obj)
end

workspace.DescendantAdded:Connect(addCoinToCache)
workspace.DescendantRemoving:Connect(removeCoinFromCache)

-- now updateCoinESP just iterates the small cached set
local function updateCoinESP(rainbowColor)
	for part in pairs(coinCache) do
		if part and part.Parent then
			applyCoinESP(part, rainbowColor)
		else
			coinCache[part] = nil
			removeCoinESP(part)
		end
	end
end

-- ══════════════════════════════════════
--   AUTO FARM
-- ══════════════════════════════════════
local function getClosestCoin()
	local c = getChar(LocalPlayer)
	local r = c and c:FindFirstChild("HumanoidRootPart")
	if not r then return nil end
	local best, bestD = nil, math.huge
	for part in pairs(coinCache) do
		if part and part.Parent then
			local d = (part.Position - r.Position).Magnitude
			if d < bestD then best = part; bestD = d end
		end
	end
	return best
end

local function farmTweenTo(part, onDone)
	if farmTweenObj then farmTweenObj:Cancel(); farmTweenObj = nil end
	local c = getChar(LocalPlayer)
	local r = c and c:FindFirstChild("HumanoidRootPart")
	if not r or not part or not part.Parent then
		if onDone then onDone(false) end; return
	end
	local dist = (part.Position - r.Position).Magnitude
	local dur  = math.clamp(dist * FARM_TWEEN_T * 0.1, 0.08, 1.2)
	farmTweenObj = TweenService:Create(r,
		TweenInfo.new(dur, Enum.EasingStyle.Linear),
		{ CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0)) }
	)
	farmTweenObj.Completed:Connect(function(state)
		farmTweenObj = nil
		if onDone then onDone(state == Enum.PlaybackState.Completed) end
	end)
	farmTweenObj:Play()
end

local function farmLoop()
	while farmActive do
		local coin = getClosestCoin()
		if not coin then
			setBadgeLabel("farm", "🌾 No coins!")
			task.wait(0.3)
		else
			farmCurrentCoin = coin
			setBadgeLabel("farm", "🌾 Farming...")
			farmTweening = true
			farmTweenTo(coin, function() farmTweening = false end)
			while farmTweening and farmActive do
				if not coin.Parent then
					if farmTweenObj then farmTweenObj:Cancel() end
					farmTweening = false; break
				end
				task.wait()
			end
		end
		task.wait(0.05)
	end
end

-- ══════════════════════════════════════
--   PLAYER ESP  (unchanged)
-- ══════════════════════════════════════
local function removeESP(player)
	local d = espHighlights[player]
	if not d then return end
	if d.hl        then d.hl:Destroy()        end
	if d.billboard then d.billboard:Destroy() end
	espHighlights[player] = nil
end

local function applyESP(player, fill, outline)
	local c = getChar(player); if not c then return end
	local r = c:FindFirstChild("HumanoidRootPart"); if not r then return end
	local d = espHighlights[player]
	local hl = d and d.hl
	if not hl or not hl.Parent then
		hl = Instance.new("Highlight")
		hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		hl.FillTransparency = 0.35; hl.OutlineTransparency = 0
		hl.Parent = Camera
	end
	hl.Adornee = c; hl.FillColor = fill; hl.OutlineColor = outline
	local bb = d and d.billboard
	if not bb or not bb.Parent then
		bb = Instance.new("BillboardGui")
		bb.AlwaysOnTop = true; bb.StudsOffset = Vector3.new(0, 3.5, 0)
		bb.Size = UDim2.new(0, 50, 0, 80); bb.ResetOnSpawn = false
		bb.LightInfluence = 0
		local function mkLine(ap, sz, pos, col)
			local f = Instance.new("Frame")
			f.AnchorPoint = ap; f.Size = sz; f.Position = pos
			f.BackgroundColor3 = col; f.BackgroundTransparency = 0
			f.BorderSizePixel = 0; f.ZIndex = 5; f.Parent = bb
		end
		local th = UDim2.new(1,0,0,2); local si = UDim2.new(0,2,1,0)
		mkLine(Vector2.new(.5,0),th,UDim2.new(.5,0,0,0),outline)
		mkLine(Vector2.new(.5,1),th,UDim2.new(.5,0,1,0),outline)
		mkLine(Vector2.new(0,.5),si,UDim2.new(0,0,.5,0),outline)
		mkLine(Vector2.new(1,.5),si,UDim2.new(1,0,.5,0),outline)
		local nl = Instance.new("TextLabel")
		nl.Size = UDim2.new(1,0,0,16); nl.Position = UDim2.new(0,0,0,-18)
		nl.BackgroundTransparency = 1; nl.TextColor3 = outline
		nl.TextSize = 11; nl.Font = Enum.Font.GothamBold
		nl.TextStrokeTransparency = 0.4; nl.TextStrokeColor3 = Color3.new(0,0,0)
		nl.Text = player.Name; nl.ZIndex = 6; nl.Name = "NL"; nl.Parent = bb
	end
	for _, ch in ipairs(bb:GetChildren()) do
		if ch:IsA("Frame") then ch.BackgroundColor3 = outline
		elseif ch:IsA("TextLabel") and ch.Name == "NL" then
			ch.TextColor3 = outline; ch.Text = player.Name end
	end
	bb.Adornee = r
	espHighlights[player] = { hl = hl, billboard = bb }
end

local function updatePlayerESP()
	for p in pairs(espHighlights) do
		if not p or not p.Parent then removeESP(p) end
	end
	for _, p in ipairs(Players:GetPlayers()) do
		if p == LocalPlayer then continue end
		local c = getChar(p)
		if not c then removeESP(p); continue end
		local fill, outline
		if hasTool(p, MURD_TOOL) then
			fill = Color3.fromRGB(200,20,20);  outline = Color3.fromRGB(255,70,70)
		elseif hasTool(p, SHERIFF_TOOL) then
			fill = Color3.fromRGB(20,70,210);  outline = Color3.fromRGB(70,140,255)
		else
			fill = Color3.fromRGB(110,30,190); outline = Color3.fromRGB(170,80,255)
		end
		applyESP(p, fill, outline)
		local d = espHighlights[p]
		if d and d.hl and d.hl.Adornee ~= c then d.hl.Adornee = c end
	end
end

-- ══════════════════════════════════════
--   CAMERA LOCK
-- ══════════════════════════════════════
local camLock = false
local function startCamLock() camLock = true end
local function stopCamLock()  camLock = false; Camera.CameraType = Enum.CameraType.Custom end
local function updateCamLock()
	if not camLock or not lockedTarget then return end
	local tc = getChar(lockedTarget)
	local tr = tc and tc:FindFirstChild("HumanoidRootPart")
	if not tr then return end
	Camera.CameraType = Enum.CameraType.Custom
	Camera.CFrame = CFrame.new(Camera.CFrame.Position, tr.Position)
end

-- ══════════════════════════════════════
--   SHERIFF HOOK
-- ══════════════════════════════════════
local function clearSheriffConn()
	if sheriffDiedConn then sheriffDiedConn:Disconnect(); sheriffDiedConn = nil end
end
local function hookSheriffDied(sheriff, char)
	clearSheriffConn(); sheriffLastChar = char
	local h = char:FindFirstChildOfClass("Humanoid"); if not h then return end
	sheriffDiedConn = h.Died:Connect(function()
		if not gunTpActive or gunTpDone or not gunLastPos then return end
		local mc = getChar(LocalPlayer)
		local mr = mc and mc:FindFirstChild("HumanoidRootPart"); if not mr then return end
		myReturnPos = mr.Position
		mr.CFrame = CFrame.new(gunLastPos + Vector3.new(0,3,0))
		gunTpDone = true; setBadgeLabel("guntp","🔫 TP'd! Get gun")
		clearSheriffConn()
	end)
end

