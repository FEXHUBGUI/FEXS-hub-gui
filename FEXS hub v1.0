-- ══════════════════════════════════════
--         UTILITY FUNCTIONS
-- ══════════════════════════════════════
local function getCharacter(player)
	return player and player.Character
end

local function hasTool(player, toolName)
	local char = getCharacter(player)
	if char and char:FindFirstChild(toolName) then return true end
	local bp = player:FindFirstChild("Backpack")
	if bp and bp:FindFirstChild(toolName) then return true end
	return false
end

local function hasAnyToolEquipped(player)
	local char = getCharacter(player)
	if not char then return false end
	for _, v in ipairs(char:GetChildren()) do
		if v:IsA("Tool") then return true end
	end
	return false
end

local function findPlayerWithTool(toolName)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and hasTool(p, toolName) then
			return p
		end
	end
	return nil
end

-- ══════════════════════════════════════
--   NOCLIP HELPERS
-- ══════════════════════════════════════
local noclipConn = nil

local function enableNoclip()
	if noclipConn then return end
	noclipConn = RunService.Stepped:Connect(function()
		local char = getCharacter(LocalPlayer)
		if not char then return end
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end)
end

local function disableNoclip()
	if noclipConn then
		noclipConn:Disconnect()
		noclipConn = nil
	end
	-- Restore collision on character parts
	local char = getCharacter(LocalPlayer)
	if char then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = true
			end
		end
	end
end

-- ══════════════════════════════════════
--   COIN ESP (RAINBOW ANIMATED)
-- ══════════════════════════════════════
local function removeCoinESP(part)
	local data = coinEspParts[part]
	if data then
		if data.hl        then pcall(function() data.hl:Destroy()        end) end
		if data.billboard then pcall(function() data.billboard:Destroy() end) end
		coinEspParts[part] = nil
	end
end

local function applyCoinESP(part, rainbowColor)
	if not part or not part.Parent then return end

	local data = coinEspParts[part]
	local hl   = data and data.hl
	if not hl or not hl.Parent then
		hl = Instance.new("Highlight")
		hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
		hl.FillTransparency    = 0.45
		hl.OutlineTransparency = 0
		hl.Parent              = Camera
	end
	hl.Adornee      = part
	hl.FillColor    = rainbowColor
	hl.OutlineColor = rainbowColor

	local bb = data and data.billboard
	if not bb or not bb.Parent then
		bb = Instance.new("BillboardGui")
		bb.AlwaysOnTop    = true
		bb.StudsOffset    = Vector3.new(0, 2.5, 0)
		bb.Size           = UDim2.new(0, 40, 0, 20)
		bb.ResetOnSpawn   = false
		bb.LightInfluence = 0
		bb.Parent         = Camera

		local lbl = Instance.new("TextLabel")
		lbl.Size                   = UDim2.new(1, 0, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.TextColor3             = Color3.new(1, 1, 1)
		lbl.TextSize               = 10
		lbl.Font                   = Enum.Font.GothamBold
		lbl.Text                   = "💰 " .. COIN_NAME
		lbl.TextStrokeTransparency = 0.3
		lbl.TextStrokeColor3       = Color3.new(0, 0, 0)
		lbl.ZIndex                 = 6
		lbl.Name                   = "CoinLabel"
		lbl.Parent                 = bb
	end

	bb.Adornee = part

	-- Update label color to rainbow
	local lbl = bb:FindFirstChild("CoinLabel")
	if lbl then lbl.TextColor3 = rainbowColor end

	coinEspParts[part] = { hl = hl, billboard = bb }
end

local function updateCoinESP(rainbowColor)
	-- Scan workspace for Coin_Server parts
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj.Name == COIN_NAME and obj:IsA("BasePart") then
			applyCoinESP(obj, rainbowColor)
		end
	end
	-- Clean up ESPs whose parts are gone
	for part in pairs(coinEspParts) do
		if not part or not part.Parent then
			removeCoinESP(part)
		end
	end
end

-- ══════════════════════════════════════
--   AUTO FARM — FIND CLOSEST COIN
-- ══════════════════════════════════════
local function getClosestCoin()
	local char = getCharacter(LocalPlayer)
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return nil end

	local closest, closestDist = nil, math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj.Name == COIN_NAME and obj:IsA("BasePart") then
			local dist = (obj.Position - root.Position).Magnitude
			if dist < closestDist then
				closest     = obj
				closestDist = dist
			end
		end
	end
	return closest
end

local farmTweenObj = nil

local function farmTweenTo(part, onDone)
	if farmTweenObj then
		farmTweenObj:Cancel()
		farmTweenObj = nil
	end
	local char = getCharacter(LocalPlayer)
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root or not part or not part.Parent then
		if onDone then onDone(false) end
		return
	end

	local dist     = (part.Position - root.Position).Magnitude
	local duration = math.clamp(dist * FARM_TWEEN_T * 0.1, 0.08, 1.2)

	farmTweenObj = TweenService:Create(
		root,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{ CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0)) }
	)
	farmTweenObj.Completed:Connect(function(state)
		farmTweenObj = nil
		if onDone then onDone(state == Enum.PlaybackState.Completed) end
	end)
	farmTweenObj:Play()
end

local function farmLoop()
	while farmActive do
		local coin = getClosestCoin()
		if not coin then
			farmStatus.Text       = "No coins!"
			farmStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
			task.wait(0.3)
		else
			farmCurrentCoin = coin
			local coinName  = coin.Name
			farmStatus.Text       = "→ " .. coinName
			farmStatus.TextColor3 = Color3.fromRGB(255, 220, 80)
			farmTweening = true

			local reached = false
			farmTweenTo(coin, function(ok)
				reached  = ok
				farmTweening = false
			end)

			-- Wait until tween finishes or coin disappears
			local t = 0
			while farmTweening and farmActive do
				if not coin.Parent then
					-- coin despawned mid-tween, cancel and re-target
					if farmTweenObj then farmTweenObj:Cancel() end
					farmTweening = false
					break
				end
				t += task.wait()
			end
		end
		task.wait(0.05)
	end
end

-- ══════════════════════════════════════
--   AUTO FARM BUTTON
-- ══════════════════════════════════════
local farmOnColor  = Color3.fromRGB(220, 160, 20)
local farmOffColor = Color3.fromRGB(200, 140, 20)

farmBtn.MouseButton1Click:Connect(function()
	farmActive = not farmActive

	if farmActive then
		farmBtn.BackgroundColor3 = farmOnColor
		farmStatus.Text          = "Starting..."
		farmStatus.TextColor3    = Color3.fromRGB(255, 220, 80)
		enableNoclip()
		task.spawn(farmLoop)
	else
		farmActive = false
		farmBtn.BackgroundColor3 = farmOffColor
		farmStatus.Text          = "Off"
		farmStatus.TextColor3    = Color3.fromRGB(200, 200, 200)
		if farmTweenObj then
			farmTweenObj:Cancel()
			farmTweenObj = nil
		end
		disableNoclip()
		farmCurrentCoin = nil
	end
end)

-- ══════════════════════════════════════
--   ESP: CHAMS (Highlight) + BOX ESP
--   for PLAYERS (unchanged)
-- ══════════════════════════════════════
local function removeESP(player)
	local data = espHighlights[player]
	if data then
		if data.hl        then data.hl:Destroy()        end
		if data.billboard then data.billboard:Destroy() end
		espHighlights[player] = nil
	end
end

local function applyESP(player, fillColor, outlineColor)
	local char = getCharacter(player)
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local data = espHighlights[player]

	local hl = data and data.hl
	if not hl or not hl.Parent then
		hl = Instance.new("Highlight")
		hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
		hl.FillTransparency    = 0.35
		hl.OutlineTransparency = 0
		hl.Parent              = Camera
	end
	hl.Adornee      = char
	hl.FillColor    = fillColor
	hl.OutlineColor = outlineColor

	local bb = data and data.billboard
	if not bb or not bb.Parent then
		bb = Instance.new("BillboardGui")
		bb.AlwaysOnTop    = true
		bb.StudsOffset    = Vector3.new(0, 3.5, 0)
		bb.Size           = UDim2.new(0, 50, 0, 80)
		bb.ResetOnSpawn   = false
		bb.LightInfluence = 0

		local function makeLine(anchorPoint, size, position, color)
			local f = Instance.new("Frame")
			f.AnchorPoint            = anchorPoint
			f.Size                   = size
			f.Position               = position
			f.BackgroundColor3       = color
			f.BackgroundTransparency = 0
			f.BorderSizePixel        = 0
			f.ZIndex                 = 5
			f.Parent                 = bb
			return f
		end

		local thickness = UDim2.new(1, 0, 0, 2)
		local side      = UDim2.new(0, 2, 1, 0)
		makeLine(Vector2.new(0.5, 0), thickness, UDim2.new(0.5, 0, 0, 0), outlineColor)
		makeLine(Vector2.new(0.5, 1), thickness, UDim2.new(0.5, 0, 1, 0), outlineColor)
		makeLine(Vector2.new(0, 0.5), side,      UDim2.new(0, 0, 0.5, 0), outlineColor)
		makeLine(Vector2.new(1, 0.5), side,      UDim2.new(1, 0, 0.5, 0), outlineColor)

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size                   = UDim2.new(1, 0, 0, 16)
		nameLabel.Position               = UDim2.new(0, 0, 0, -18)
		nameLabel.BackgroundTransparency = 1
		nameLabel.TextColor3             = outlineColor
		nameLabel.TextSize               = 11
		nameLabel.Font                   = Enum.Font.GothamBold
		nameLabel.TextStrokeTransparency = 0.4
		nameLabel.TextStrokeColor3       = Color3.new(0, 0, 0)
		nameLabel.Text                   = player.Name
		nameLabel.ZIndex                 = 6
		nameLabel.Name                   = "NameLabel"
		nameLabel.Parent                 = bb
	end

	for _, child in ipairs(bb:GetChildren()) do
		if child:IsA("Frame") then
			child.BackgroundColor3 = outlineColor
		elseif child:IsA("TextLabel") and child.Name == "NameLabel" then
			child.TextColor3 = outlineColor
			child.Text       = player.Name
		end
	end

	bb.Adornee = root
	espHighlights[player] = { hl = hl, billboard = bb }
end

local function updatePlayerESP()
	for player in pairs(espHighlights) do
		if not player or not player.Parent then removeESP(player) end
	end
	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end
		local char = getCharacter(player)
		if not char then removeESP(player) continue end

		local fillColor, outlineColor
		if hasTool(player, MURD_TOOL) then
			fillColor    = Color3.fromRGB(200, 20,  20)
			outlineColor = Color3.fromRGB(255, 70,  70)
		elseif hasTool(player, SHERIFF_TOOL) then
			fillColor    = Color3.fromRGB(20,  70,  210)
			outlineColor = Color3.fromRGB(70,  140, 255)
		else
			fillColor    = Color3.fromRGB(110, 30,  190)
			outlineColor = Color3.fromRGB(170, 80,  255)
		end

		applyESP(player, fillColor, outlineColor)

		local data = espHighlights[player]
		if data and data.hl and data.hl.Adornee ~= char then
			data.hl.Adornee = char
		end
	end
end

-- ══════════════════════════════════════
--   CAMERA HARD LOCK-ON
-- ══════════════════════════════════════
local camLockActive = false

local function startCameraLock()
	camLockActive = true
end

local function stopCameraLock()
	camLockActive = false
	Camera.CameraType = Enum.CameraType.Custom
end

local function updateCameraLock()
	if not camLockActive or not lockedTarget then return end
	local targetChar = getCharacter(lockedTarget)
	local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
	if not targetRoot then return end
	Camera.CameraType = Enum.CameraType.Custom
	Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetRoot.Position)
end

-- ══════════════════════════════════════
--   LOCK MURD BUTTON LOGIC
-- ══════════════════════════════════════
local function doLock(toolName, label, statusLbl, otherStatusLbl)
	local target = findPlayerWithTool(toolName)
	if target then
		lockedTarget = target
		lockMode     = label
		startCameraLock()
		statusLbl.Text       = "🔒 " .. target.Name
		statusLbl.TextColor3 = Color3.fromRGB(80, 255, 140)
		otherStatusLbl.Text       = "Idle"
		otherStatusLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
	else
		statusLbl.Text       = "Not found"
		statusLbl.TextColor3 = Color3.fromRGB(255, 160, 80)
	end
end

murdBtn.MouseButton1Click:Connect(function()
	if lockedTarget and lockMode == "Murd" then
		lockedTarget = nil
		lockMode     = nil
		stopCameraLock()
		murdStatus.Text       = "Unlocked"
		murdStatus.TextColor3 = Color3.fromRGB(200, 200, 200)
	else
		doLock(MURD_TOOL, "Murd", murdStatus, farmStatus)
	end
end)

-- ══════════════════════════════════════
--        FAKE SPEED BUTTON
-- ══════════════════════════════════════
local speedOnColor  = Color3.fromRGB(110, 50, 220)
local speedOffColor = Color3.fromRGB(80, 35, 160)

speedBtn.MouseButton1Click:Connect(function()
	fakeSpeedOn = not fakeSpeedOn
	if fakeSpeedOn then
		speedBtn.BackgroundColor3 = speedOnColor
		speedStatus.Text          = "Jump!"
		speedStatus.TextColor3    = Color3.fromRGB(200, 160, 255)
	else
		speedBtn.BackgroundColor3 = speedOffColor
		speedStatus.Text          = "Off"
		speedStatus.TextColor3    = Color3.fromRGB(200, 200, 200)
		local char = getCharacter(LocalPlayer)
		local h    = char and char:FindFirstChildOfClass("Humanoid")
		if h then h.WalkSpeed = 16 end
	end
end)

-- ══════════════════════════════════════
--        GUN TP BUTTON
-- ══════════════════════════════════════
local gunTpOnColor  = Color3.fromRGB(40, 180, 110)
local gunTpOffColor = Color3.fromRGB(30, 130, 90)

local function clearSheriffDiedConn()
	if sheriffDiedConn then
		sheriffDiedConn:Disconnect()
		sheriffDiedConn = nil
	end
end

local function hookSheriffDied(sheriff, char)
	clearSheriffDiedConn()
	sheriffLastChar = char
	local h = char:FindFirstChildOfClass("Humanoid")
	if not h then return end

	sheriffDiedConn = h.Died:Connect(function()
		if not gunTpActive or gunTpDone then return end
		if not gunLastPos then return end
		local myChar = getCharacter(LocalPlayer)
		local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myRoot then return end
		myReturnPos = myRoot.Position
		myRoot.CFrame = CFrame.new(gunLastPos + Vector3.new(0, 3, 0))
		gunTpDone = true
		gunTpStatus.Text       = "TP'd! Get gun"
		gunTpStatus.TextColor3 = Color3.fromRGB(80, 255, 160)
		clearSheriffDiedConn()
	end)
end

gunTpBtn.MouseButton1Click:Connect(function()
	gunTpActive = not gunTpActive

	if gunTpActive then
		myReturnPos = nil
		gunTpDone   = false
		gunTpBtn.BackgroundColor3 = gunTpOnColor

		local sheriff = currentSheriff
		if sheriff then
			local char = getCharacter(sheriff)
			local h    = char and char:FindFirstChildOfClass("Humanoid")
			if h and h.Health <= 0 and gunLastPos then
				gunTpStatus.Text       = "Sheriff dead — tp'ing..."
				gunTpStatus.TextColor3 = Color3.fromRGB(255, 220, 80)
			else
				gunTpStatus.Text       = "Tracking: " .. sheriff.Name
				gunTpStatus.TextColor3 = Color3.fromRGB(100, 255, 180)
			end
		else
			gunTpStatus.Text       = "No sheriff yet"
			gunTpStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
		end
	else
		gunTpDone   = false
		myReturnPos = nil
		gunTpBtn.BackgroundColor3 = gunTpOffColor
		gunTpStatus.Text          = "Standby"
		gunTpStatus.TextColor3    = Color3.fromRGB(200, 200, 200)
	end
end)

-- ══════════════════════════════════════
--            MAIN HEARTBEAT LOOP
-- ══════════════════════════════════════
RunService.Heartbeat:Connect(function(dt)
	-- Advance rainbow hue for coin ESP
	rainbowHue = (rainbowHue + dt * 80) % 360
	local rainbowColor = Color3.fromHSV(rainbowHue / 360, 0.55, 1)

	updatePlayerESP()
	updateCameraLock()
	-- Always update coin ESP (rainbow) regardless of farm toggle
	updateCoinESP(rainbowColor)

	if lockedTarget and lockMode == "Murd" then
		if not hasTool(lockedTarget, MURD_TOOL) or not getCharacter(lockedTarget) then
			local newTarget = findPlayerWithTool(MURD_TOOL)
			if newTarget then
				lockedTarget          = newTarget
				murdStatus.Text       = "Auto: " .. newTarget.Name
				murdStatus.TextColor3 = Color3.fromRGB(255, 220, 60)
			else
				lockedTarget = nil
				lockMode     = nil
				stopCameraLock()
				murdStatus.Text       = "Lost tool"
				murdStatus.TextColor3 = Color3.fromRGB(255, 130, 60)
			end
		end
	end

	do
		local sheriff = findPlayerWithTool(SHERIFF_TOOL)
		if sheriff ~= currentSheriff then
			currentSheriff = sheriff
			gunLastPos     = nil
			clearSheriffDiedConn()
			if sheriff then
				local char = getCharacter(sheriff)
				if char then hookSheriffDied(sheriff, char) end
			end
		end

		if currentSheriff then
			local char = getCharacter(currentSheriff)
			if char then
				if char ~= sheriffLastChar then
					hookSheriffDied(currentSheriff, char)
				end
				local root = char:FindFirstChild("HumanoidRootPart")
				local h    = char:FindFirstChildOfClass("Humanoid")
				if root and h and h.Health > 0 then
					gunLastPos = root.Position
				end
			end
		end
	end

	if gunTpActive and not gunTpDone and currentSheriff then
		local char = getCharacter(currentSheriff)
		local h    = char and char:FindFirstChildOfClass("Humanoid")
		if h and h.Health <= 0 and gunLastPos then
			local myChar = getCharacter(LocalPlayer)
			local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
			if myRoot then
				myReturnPos = myRoot.Position
				myRoot.CFrame = CFrame.new(gunLastPos + Vector3.new(0, 3, 0))
				gunTpDone = true
				gunTpStatus.Text       = "TP'd! Get gun"
				gunTpStatus.TextColor3 = Color3.fromRGB(80, 255, 160)
			end
		end
	end

	if gunTpActive and gunTpDone and myReturnPos then
		if hasTool(LocalPlayer, SHERIFF_TOOL) then
			local myChar = getCharacter(LocalPlayer)
			local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
			if myRoot then
				myRoot.CFrame = CFrame.new(myReturnPos + Vector3.new(0, 3, 0))
				gunTpStatus.Text       = "Returned home!"
				gunTpStatus.TextColor3 = Color3.fromRGB(80, 200, 255)
				myReturnPos = nil
				gunTpDone   = false
				gunTpActive = false
				gunTpBtn.BackgroundColor3 = gunTpOffColor
				task.delay(2, function()
					gunTpStatus.Text       = "Standby"
					gunTpStatus.TextColor3 = Color3.fromRGB(200, 200, 200)
				end)
			end
		end
	end

	if fakeSpeedOn then
		local char = getCharacter(LocalPlayer)
		if not char then return end
		local h = char:FindFirstChildOfClass("Humanoid")
		if not h then return end

		if not hasAnyToolEquipped(LocalPlayer) then
			h.WalkSpeed            = 16
			speedStatus.Text       = "Equip tool!"
			speedStatus.TextColor3 = Color3.fromRGB(255, 180, 60)
			return
		end

		if h.FloorMaterial == Enum.Material.Air then
			h.WalkSpeed            = FAKE_SPEED
			speedStatus.Text       = "🚀 Boost!"
			speedStatus.TextColor3 = Color3.fromRGB(140, 255, 180)
		else
			h.WalkSpeed            = 16
			speedStatus.Text       = "Jump!"
			speedStatus.TextColor3 = Color3.fromRGB(200, 160, 255)
		end
	end
end)

-- ══════════════════════════════════════
--         PLAYER LEAVE CLEANUP
-- ══════════════════════════════════════
Players.PlayerRemoving:Connect(function(player)
	removeESP(player)
	if lockedTarget == player then
		lockedTarget = nil
		lockMode     = nil
		stopCameraLock()
		murdStatus.Text = "Left"
	end
	if currentSheriff == player then
		currentSheriff = nil
		clearSheriffDiedConn()
		gunLastPos = nil
	end
end)

print("[Rain Hub] Loaded. Auto Farm + Rainbow Coin ESP active.")
