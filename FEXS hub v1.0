bSub.TextTransparency = 1
bSub.ZIndex           = 12
bSub.Parent           = bPanel

local shimAngle = 0
local shimConn  = RunService.Heartbeat:Connect(function(dt)
	shimAngle    = (shimAngle + dt * 60) % 360
	bGrad.Rotation = shimAngle
end)

local function bannerFade(show)
	local t    = show and 0 or 1
	local pos  = show and UDim2.new(0.5, 0, 0, 60) or UDim2.new(0.5, 0, 0, 40)
	local info = show
		and TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		or  TweenInfo.new(0.60, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
	tw(bPanel,  {BackgroundTransparency = t, Position = pos}, info)
	tw(bStroke, {Transparency = t},            info)
	tw(bAccent, {BackgroundTransparency = t},  info)
	tw(bMain,   {TextTransparency = t},        info)
	tw(bSub,    {TextTransparency = t},        info)
	tw(bIcon,   {TextTransparency = t},        info)
end

task.spawn(function()
	task.wait(0.3);  bannerFade(true)
	task.wait(3.8);  bannerFade(false)
	task.wait(0.9);  shimConn:Disconnect(); bannerGui:Destroy()
end)

