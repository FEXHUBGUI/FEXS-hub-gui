--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer
local cam = workspace.CurrentCamera

--// GUI
local gui = Instance.new("ScreenGui")
gui.Name = "DebugPowerUI"
gui.ResetOnSpawn = false
gui.Parent = lp:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 260, 0, 180)
frame.Position = UDim2.new(0.5, -130, 0.6, 0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Parent = frame

--// RAINBOW
task.spawn(function()
	local i = 0
	while gui.Parent do
		i += 1
		local hue = (i % 360) / 360
		local c = Color3.fromHSV(hue, 1, 1)
		frame.BackgroundColor3 = Color3.fromHSV(hue, 0.25, 0.15)
		stroke.Color = c
		task.wait(0.03)
	end
end)

--// BUTTON FACTORY
local function makeButton(text, y)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(0, 240, 0, 40)
	b.Position = UDim2.new(0, 10, 0, y)
	b.Text = text
	b.Font = Enum.Font.GothamBold
	b.TextSize = 14
	b.TextColor3 = Color3.new(1,1,1)
	b.BackgroundColor3 = Color3.fromRGB(40,40,40)
	b.Parent = frame

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, 8)
	c.Parent = b

	return b
end

--// STATE
local lastGunPos = nil
local lockTarget = nil
local locking = false

--// TRACK TOOL POSITIONS (your game logic)
local function getRoleTarget(toolName)
	for _, plr in ipairs(Players:GetPlayers()) do
		local char = plr.Character
		if char then
			local tool = char:FindFirstChild(toolName)
			if tool then
				local hrp = char:FindFirstChild("HumanoidRootPart")
				if hrp then
					return plr, hrp
				end
			end
		end
	end
	return nil, nil
end

-- track dropped gun position
workspace.ChildAdded:Connect(function(obj)
	if obj:IsA("Tool") and obj.Name == "Gun" then
		local handle = obj:FindFirstChild("Handle")
		if handle then
			task.spawn(function()
				while obj.Parent == workspace and handle do
					lastGunPos = handle.Position
					task.wait(0.1)
				end
			end)
		end
	end
end)

--// TP BUTTON
local tpBtn = makeButton("TP TO GUN", 10)

tpBtn.MouseButton1Click:Connect(function()
	local char = lp.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if hrp and lastGunPos then
		hrp.CFrame = CFrame.new(lastGunPos + Vector3.new(0,3,0))
	end
end)

--// LOCK FUNCTION
local function startLock(toolName)
	locking = true

	RunService:BindToRenderStep("LOCK_"..toolName, 1, function()
		if not locking then return end

		local _, targetHRP = getRoleTarget(toolName)
		if targetHRP then
			lockTarget = targetHRP
			cam.CFrame = CFrame.new(cam.CFrame.Position, targetHRP.Position)
		end
	end)
end

local function stopLock(toolName)
	locking = false
	RunService:UnbindFromRenderStep("LOCK_"..toolName)
end

--// LOCK SHERIFF (Gun)
local sheriffBtn = makeButton("LOCK ON SHERIFF", 60)

sheriffBtn.MouseButton1Click:Connect(function()
	if locking then
		stopLock("Gun")
	else
		startLock("Gun")
	end
end)

--// LOCK MURDERER (Knife)
local murderBtn = makeButton("LOCK ON MURDERER", 110)

murderBtn.MouseButton1Click:Connect(function()
	if locking then
		stopLock("Knife")
	else
		startLock("Knife")
	end
end)

--// DEBUG WALL SEE SYSTEM (Highlight ESP style but for YOUR GAME)
local highlights = {}

local function applyHighlight(plr, color)
	if highlights[plr] then highlights[plr]:Destroy() end

	local char = plr.Character
	if not char then return end

	local h = Instance.new("Highlight")
	h.FillTransparency = 0.5
	h.OutlineTransparency = 0
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	h.Parent = char
	h.FillColor = color

	highlights[plr] = h
end

local function updateHighlights()
	for _, plr in ipairs(Players:GetPlayers()) do
		local char = plr.Character
		if not char then continue end

		if char:FindFirstChild("Gun") then
			applyHighlight(plr, Color3.fromRGB(80,160,255)) -- blue
		elseif char:FindFirstChild("Knife") then
			applyHighlight(plr, Color3.fromRGB(255,80,80)) -- red
		else
			applyHighlight(plr, Color3.fromRGB(170,80,255)) -- purple
		end
	end
end

RunService.RenderStepped:Connect(updateHighlights)

-- name tags
local function makeBillboard(plr, text, color)
	local char = plr.Character
	if not char then return end

	local head = char:FindFirstChild("Head")
	if not head then return end

	if head:FindFirstChild("RoleTag") then head.RoleTag:Destroy() end

	local bb = Instance.new("BillboardGui")
	bb.Name = "RoleTag"
	bb.Size = UDim2.new(0,200,0,50)
	bb.StudsOffset = Vector3.new(0,2,0)
	bb.AlwaysOnTop = true
	bb.Parent = head

	local tl = Instance.new("TextLabel")
	tl.Size = UDim2.new(1,0,1,0)
	tl.BackgroundTransparency = 1
	tl.Text = text
	tl.TextColor3 = color
	tl.Font = Enum.Font.GothamBold
	tl.TextScaled = true
	tl.Parent = bb
end

RunService.RenderStepped:Connect(function()
	for _, plr in ipairs(Players:GetPlayers()) do
		local char = plr.Character
		if not char then continue end

		if char:FindFirstChild("Knife") then
			makeBillboard(plr, "Red = MURDERER", Color3.fromRGB(255,80,80))
		elseif char:FindFirstChild("Gun") then
			makeBillboard(plr, "Blue = SHERIFF", Color3.fromRGB(80,160,255))
		else
			makeBillboard(plr, "Purple = INNOCENT", Color3.fromRGB(170,80,255))
		end
	end
end)
