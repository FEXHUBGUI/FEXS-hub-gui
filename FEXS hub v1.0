--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "RainHubMM2"

-- MAIN (CENTERED)
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,380,0,340)
main.Position = UDim2.new(0.5,-190,0.5,-170)
main.BackgroundColor3 = Color3.fromRGB(10,15,25)
main.Active = true
main.Draggable = true
Instance.new("UICorner", main)

-- WATER SHADER (FAKE)
local water = Instance.new("Frame", main)
water.Size = UDim2.new(1,0,1,0)
water.BackgroundTransparency = 0.8
water.BackgroundColor3 = Color3.fromRGB(0,80,150)

task.spawn(function()
	while true do
		TweenService:Create(water,TweenInfo.new(3,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{
			BackgroundTransparency = 0.85
		}):Play()
		task.wait(3)
		TweenService:Create(water,TweenInfo.new(3,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{
			BackgroundTransparency = 0.75
		}):Play()
		task.wait(3)
	end
end)

-- TITLE
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,35)
title.Text = "Rain Hub MM2"
title.Font = Enum.Font.Arcade
title.TextColor3 = Color3.fromRGB(0,170,255)
title.BackgroundTransparency = 1

-- RAIN (ACTUALLY FALLING)
for i = 1,30 do
	local drop = Instance.new("ImageLabel", main)
	drop.Image = "rbxassetid://133078236"
	drop.Size = UDim2.new(0,10,0,25)
	drop.BackgroundTransparency = 1
	
	task.spawn(function()
		while true do
			drop.Position = UDim2.new(math.random(),0,-0.2,0)
			local t = TweenService:Create(drop,TweenInfo.new(1.5,Enum.EasingStyle.Linear),{
				Position = UDim2.new(drop.Position.X.Scale,0,1.2,0)
			})
			t:Play()
			t.Completed:Wait()
		end
	end)
end

-- TABS
local tabHolder = Instance.new("Frame", main)
tabHolder.Size = UDim2.new(1,0,0,30)
tabHolder.Position = UDim2.new(0,0,0,35)
tabHolder.BackgroundTransparency = 1

local content = Instance.new("Frame", main)
content.Size = UDim2.new(1,0,1,-65)
content.Position = UDim2.new(0,0,0,65)
content.BackgroundTransparency = 1

local tabs = {"Murderer","Sheriff","Visual"}
local tabFrames = {}

for i,name in pairs(tabs) do
	local btn = Instance.new("TextButton", tabHolder)
	btn.Size = UDim2.new(1/#tabs,0,1,0)
	btn.Position = UDim2.new((i-1)/#tabs,0,0,0)
	btn.Text = name
	btn.Font = Enum.Font.Arcade
	btn.TextColor3 = Color3.new(1,1,1)
	btn.BackgroundColor3 = Color3.fromRGB(20,25,40)
	
	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = Color3.fromRGB(0,150,255)
	stroke.Thickness = 2
	
	Instance.new("UICorner", btn)

	local frame = Instance.new("Frame", content)
	frame.Size = UDim2.new(1,0,1,0)
	frame.Visible = false
	frame.BackgroundTransparency = 1

	tabFrames[name] = frame

	btn.MouseButton1Click:Connect(function()
		for _,f in pairs(tabFrames) do f.Visible = false end
		frame.Visible = true
	end)
end

tabFrames["Visual"].Visible = true

-- BUTTON CREATOR
function makeBtn(parent,text,y,color,callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.85,0,0,45)
	b.Position = UDim2.new(0.075,0,0,y)
	b.Text = text.." [OFF]"
	b.Font = Enum.Font.Arcade
	b.TextColor3 = Color3.new(1,1,1)
	b.BackgroundColor3 = Color3.fromRGB(15,15,25)
	
	local stroke = Instance.new("UIStroke", b)
	stroke.Color = color
	stroke.Thickness = 2
	
	Instance.new("UICorner", b)

	local state = false

	b.MouseButton1Click:Connect(function()
		state = not state
		b.Text = text.." ["..(state and "ON" or "OFF").."]"
		callback(state)
	end)
end

-- ESP
local espOn = false

RunService.RenderStepped:Connect(function()
	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			local char = p.Character

			if char:FindFirstChild("Highlight") then
				char.Highlight:Destroy()
			end

			if espOn then
				local h = Instance.new("Highlight", char)

				if p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then
					h.FillColor = Color3.fromRGB(255,0,0)
				elseif p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then
					h.FillColor = Color3.fromRGB(0,150,255)
				else
					h.FillColor = Color3.fromRGB(0,255,0)
				end
			end
		end
	end
end)

-- VISUAL TAB
makeBtn(tabFrames["Visual"],"ESP",10,Color3.fromRGB(0,150,255),function(v)
	espOn = v
end)

-- LOCK SYSTEM (SMART)
local locking = false
local mode = nil

function getTarget()
	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			if mode == "Sheriff" then
				if p.Backpack:FindFirstChild("Gun") or (p.Character and p.Character:FindFirstChild("Gun")) then
					return p
				end
			elseif mode == "Murderer" then
				if p.Backpack:FindFirstChild("Knife") or (p.Character and p.Character:FindFirstChild("Knife")) then
					return p
				end
			end
		end
	end
end

RunService.RenderStepped:Connect(function()
	if locking then
		local target = getTarget()
		if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
			local pos = target.Character.HumanoidRootPart.Position
			workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame:Lerp(
				CFrame.new(workspace.CurrentCamera.CFrame.Position, pos),
				0.2
			)
		end
	end
end)

-- MURDERER TAB
makeBtn(tabFrames["Murderer"],"Shoot Sheriff",10,Color3.fromRGB(0,150,255),function(v)
	locking = v
	mode = "Sheriff"
end)

-- SHERIFF TAB
makeBtn(tabFrames["Sheriff"],"Shoot Murderer",10,Color3.fromRGB(255,50,50),function(v)
	locking = v
	mode = "Murderer"
end)
