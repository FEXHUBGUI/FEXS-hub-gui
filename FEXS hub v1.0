bGrad.Color=ColorSequence.new({
	ColorSequenceKeypoint.new(0,Color3.fromRGB(20,100,220)),
	ColorSequenceKeypoint.new(0.5,Color3.fromRGB(100,180,255)),
	ColorSequenceKeypoint.new(1,Color3.fromRGB(20,100,220)),
});bGrad.Parent=bAccent

local function mkLbl(parent,text,size,pos,tsize,font,color,ta,zi)
	local l=Instance.new("TextLabel");l.Size=size;l.Position=pos
	l.BackgroundTransparency=1;l.Text=text;l.TextSize=tsize;l.Font=font
	l.TextColor3=color;l.TextTransparency=1;l.ZIndex=zi or 12
	if ta then l.TextXAlignment=ta end;l.Parent=parent;return l
end

local bIcon=mkLbl(bPanel,"🌧️",UDim2.new(0,36,0,36),UDim2.new(0,12,0.5,-18),22,Enum.Font.GothamBold,Color3.new(1,1,1))
local bMain=mkLbl(bPanel,"Welcome to Rain Hub v11.0!",UDim2.new(1,-56,0,24),UDim2.new(0,50,0,8),16,Enum.Font.GothamBold,Color3.fromRGB(160,210,255),Enum.TextXAlignment.Left)
local bSub=mkLbl(bPanel,"⚡ WE UPDATE ALMOST EVERYDAY!",UDim2.new(1,-56,0,16),UDim2.new(0,50,0,32),11,Enum.Font.Gotham,Color3.fromRGB(80,160,255),Enum.TextXAlignment.Left)

local shimAngle=0
local shimConn=RunService.Heartbeat:Connect(function(dt)
	shimAngle=(shimAngle+dt*60)%360;bGrad.Rotation=shimAngle
end)

local function bannerFade(show)
	local t=show and 0 or 1
	local pos=show and UDim2.new(0.5,0,0,60) or UDim2.new(0.5,0,0,40)
	local info=show and TweenInfo.new(0.55,Enum.EasingStyle.Quint,Enum.EasingDirection.Out)
		or TweenInfo.new(0.6,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
	tw(bPanel,{BackgroundTransparency=t,Position=pos},info)
	tw(bStroke,{Transparency=t},info);tw(bAccent,{BackgroundTransparency=t},info)
	tw(bMain,{TextTransparency=t},info);tw(bSub,{TextTransparency=t},info);tw(bIcon,{TextTransparency=t},info)
end
task.spawn(function()
	task.wait(0.3);bannerFade(true)
	task.wait(3.8);bannerFade(false)
	task.wait(0.9);shimConn:Disconnect();bannerGui:Destroy()
end)

