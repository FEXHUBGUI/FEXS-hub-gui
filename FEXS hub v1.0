--   FLOATING RED LOCK MURD BUTTON
-- ══════════════════════════════════════
local CUBE=80
local murdFloatBtn=Instance.new("TextButton")
murdFloatBtn.Size=UDim2.new(0,CUBE,0,CUBE);murdFloatBtn.Position=UDim2.new(0,20,0,140)
murdFloatBtn.BackgroundColor3=Color3.fromRGB(180,35,35);murdFloatBtn.BorderSizePixel=0
murdFloatBtn.Text="";murdFloatBtn.AutoButtonColor=false
murdFloatBtn.ZIndex=25;murdFloatBtn.Visible=false;murdFloatBtn.Parent=screenGui
Instance.new("UICorner",murdFloatBtn).CornerRadius=UDim.new(0,14)

local mfTop=Instance.new("TextLabel");mfTop.Size=UDim2.new(1,-8,0,22)
mfTop.Position=UDim2.new(0,4,0,14);mfTop.BackgroundTransparency=1;mfTop.Text="Lock"
mfTop.TextColor3=Color3.new(1,1,1);mfTop.TextSize=13;mfTop.Font=Enum.Font.GothamBold
mfTop.TextXAlignment=Enum.TextXAlignment.Center;mfTop.ZIndex=26;mfTop.Parent=murdFloatBtn

local mfBot=Instance.new("TextLabel");mfBot.Size=UDim2.new(1,-8,0,20)
mfBot.Position=UDim2.new(0,4,0,36);mfBot.BackgroundTransparency=1;mfBot.Text="Murd"
mfBot.TextColor3=Color3.fromRGB(255,180,180);mfBot.TextSize=11;mfBot.Font=Enum.Font.Gotham
mfBot.TextXAlignment=Enum.TextXAlignment.Center;mfBot.ZIndex=26;mfBot.Parent=murdFloatBtn

local mfStatus=Instance.new("TextLabel");mfStatus.Size=UDim2.new(0,CUBE,0,16)
mfStatus.Position=UDim2.new(0,20,0,140+CUBE+4);mfStatus.BackgroundTransparency=1
mfStatus.Text="Click to lock";mfStatus.TextColor3=Color3.fromRGB(200,200,200)
mfStatus.TextSize=10;mfStatus.Font=Enum.Font.Gotham
mfStatus.TextXAlignment=Enum.TextXAlignment.Center;mfStatus.ZIndex=25
mfStatus.Visible=false;mfStatus.Parent=screenGui

local mfPinned=false
local mfPinBtn=Instance.new("TextButton");mfPinBtn.Size=UDim2.new(0,22,0,22)
mfPinBtn.Position=UDim2.new(1,-10,0,-12);mfPinBtn.BackgroundColor3=Color3.fromRGB(20,40,90)
mfPinBtn.BorderSizePixel=0;mfPinBtn.Text="📌";mfPinBtn.TextSize=11
mfPinBtn.Font=Enum.Font.GothamBold;mfPinBtn.AutoButtonColor=false
mfPinBtn.ZIndex=28;mfPinBtn.Parent=murdFloatBtn
Instance.new("UICorner",mfPinBtn).CornerRadius=UDim.new(1,0)

local mfDragging,mfDragStart,mfDragPos=false,nil,nil
murdFloatBtn.InputBegan:Connect(function(inp)
	if mfPinned then return end
	if inp.UserInputType==Enum.UserInputType.MouseButton1
	or inp.UserInputType==Enum.UserInputType.Touch then
		mfDragging=true;mfDragStart=inp.Position;mfDragPos=murdFloatBtn.Position
		inp.Changed:Connect(function()
			if inp.UserInputState==Enum.UserInputState.End then mfDragging=false end
		end)
	end
end)
UserInputService.InputChanged:Connect(function(inp)
	if not mfDragging or mfPinned then return end
	if inp.UserInputType==Enum.UserInputType.MouseMovement
	or inp.UserInputType==Enum.UserInputType.Touch then
		local d=inp.Position-mfDragStart
		local nx=mfDragPos.X.Offset+d.X;local ny=mfDragPos.Y.Offset+d.Y
		murdFloatBtn.Position=UDim2.new(mfDragPos.X.Scale,nx,mfDragPos.Y.Scale,ny)
		mfStatus.Position=UDim2.new(mfDragPos.X.Scale,nx,mfDragPos.Y.Scale,ny+CUBE+4)
	end
end)
mfPinBtn.MouseButton1Click:Connect(function()
	mfPinned=not mfPinned
	mfPinBtn.BackgroundColor3=mfPinned and Color3.fromRGB(60,200,100) or Color3.fromRGB(20,40,90)
	mfPinBtn.Text=mfPinned and "🔒" or "📌"
end)

-- ══════════════════════════════════════
--   BUILD MENU ROWS
-- ══════════════════════════════════════
local murdLockOn=false
local setMurd=nil

local function showMurdFloat()
	murdFloatBtn.Visible=true;mfStatus.Visible=true;mfStatus.Text="Click to lock"
end
local function hideMurdFloat()
	if murdLockOn then
		murdLockOn=false;lockedTarget=nil;lockMode=nil;stopCamLock();removeBadge("murd")
		mfStatus.Text="Click to lock";murdFloatBtn.BackgroundColor3=Color3.fromRGB(180,35,35)
	end
	murdFloatBtn.Visible=false;mfStatus.Visible=false
end

local setFarm=makeToggleRow("🌾","Auto Farm","Tween to coins + noclip",
	function(on,hint)
		farmActive=on
		if on then hint.Text="Farming closest...";enableNoclip()
			makeBadge("farm","🌾 Farming...",Color3.fromRGB(180,125,15));task.spawn(farmLoop)
		else hint.Text="Off"
			if farmTweenObj then farmTweenObj:Cancel();farmTweenObj=nil end
			farmCurrentCoin=nil;disableNoclip();removeBadge("farm")
		end
	end)

setMurd=makeToggleRow("🔒","Lock Murd","Shows/hides the lock button",
	function(on,hint)
		if on then hint.Text="Button visible";showMurdFloat()
		else hint.Text="Off";hideMurdFloat() end
	end)

murdFloatBtn.MouseButton1Click:Connect(function()
	if murdLockOn then
		murdLockOn=false;lockedTarget=nil;lockMode=nil;stopCamLock();removeBadge("murd")
		mfStatus.Text="Click to lock";murdFloatBtn.BackgroundColor3=Color3.fromRGB(180,35,35)
	else
		local t=findWithTool(MURD_TOOL)
		if t then
			murdLockOn=true;lockedTarget=t;lockMode="Murd";startCamLock()
			mfStatus.Text="🔒 "..t.Name;murdFloatBtn.BackgroundColor3=Color3.fromRGB(220,60,60)
			makeBadge("murd","🔒 "..t.Name,Color3.fromRGB(160,30,30))
		else mfStatus.Text="No murd found!" end
	end
end)

local setSpeed=makeToggleRow("🚀","Fake Speed","Jump for mid-air boost",
	function(on,hint)
		fakeSpeedOn=on
		if on then hint.Text="Active — jump!"
			makeBadge("speed","🚀 Fake Speed",Color3.fromRGB(70,30,145))
		else hint.Text="Off"
			local c=getChar(LocalPlayer);local h=c and c:FindFirstChildOfClass("Humanoid")
			if h then h.WalkSpeed=16 end;removeBadge("speed")
		end
	end)

local setGunTp;setGunTp=makeToggleRow("🔫","Gun TP","TP to gun when sheriff dies",
	function(on,hint)
		gunTpActive=on
		if on then myReturnPos=nil;gunTpDone=false
			if currentSheriff then
				hint.Text="Tracking "..currentSheriff.Name
				makeBadge("guntp","🔫 Tracking "..currentSheriff.Name,Color3.fromRGB(25,110,78))
			else hint.Text="Waiting...";makeBadge("guntp","🔫 Waiting...",Color3.fromRGB(25,110,78)) end
		else gunTpDone=false;myReturnPos=nil;hint.Text="Off";removeBadge("guntp") end
	end)

-- ══════════════════════════════════════
--   MAIN HEARTBEAT
-- ══════════════════════════════════════
local espThrottle=0
local fpsAccum=0

RunService.Heartbeat:Connect(function(dt)
	fpsAccum+=dt
	local frameTime=1/cfg.fpsCap
	if fpsAccum<frameTime then return end
	fpsAccum=fpsAccum%frameTime

	rainbowHue=(rainbowHue+dt*80)%360
	local rbColor=Color3.fromHSV(rainbowHue/360,0.6,1)

	updateCoinESP(rbColor)
	espThrottle+=1
	if espThrottle>=3 then espThrottle=0;updatePlayerESP() end
	updateCamLock()

	if murdLockOn and lockedTarget and lockMode=="Murd" then
		if not hasTool(lockedTarget,MURD_TOOL) or not getChar(lockedTarget) then
			local nt=findWithTool(MURD_TOOL)
			if nt then
				lockedTarget=nt;startCamLock()
				setBadgeLabel("murd","🔒 "..nt.Name);mfStatus.Text="🔒 "..nt.Name
			else
				murdLockOn=false;lockedTarget=nil;lockMode=nil;stopCamLock()
				removeBadge("murd");mfStatus.Text="Click to lock"
				murdFloatBtn.BackgroundColor3=Color3.fromRGB(180,35,35)
			end
		else mfStatus.Text="🔒 "..lockedTarget.Name end
	end

	do
		local s=findWithTool(SHERIFF_TOOL)
		if s~=currentSheriff then
			currentSheriff=s;gunLastPos=nil;clearSheriffConn()
			if s then local c=getChar(s);if c then hookSheriffDied(s,c) end end
		end
		if currentSheriff then
			local c=getChar(currentSheriff)
			if c then
				if c~=sheriffLastChar then hookSheriffDied(currentSheriff,c) end
				local r=c:FindFirstChild("HumanoidRootPart")
				local h=c:FindFirstChildOfClass("Humanoid")
				if r and h and h.Health>0 then gunLastPos=r.Position end
			end
		end
	end

	if gunTpActive and not gunTpDone and currentSheriff then
		local c=getChar(currentSheriff);local h=c and c:FindFirstChildOfClass("Humanoid")
		if h and h.Health<=0 and gunLastPos then
			local mc=getChar(LocalPlayer);local mr=mc and mc:FindFirstChild("HumanoidRootPart")
			if mr then
				myReturnPos=mr.Position;mr.CFrame=CFrame.new(gunLastPos+Vector3.new(0,3,0))
				gunTpDone=true;setBadgeLabel("guntp","🔫 TP'd! Get gun")
			end
		end
	end

	if gunTpActive and gunTpDone and myReturnPos then
		if hasTool(LocalPlayer,SHERIFF_TOOL) then
			local mc=getChar(LocalPlayer);local mr=mc and mc:FindFirstChild("HumanoidRootPart")
			if mr then
				mr.CFrame=CFrame.new(myReturnPos+Vector3.new(0,3,0))
				myReturnPos=nil;gunTpDone=false;gunTpActive=false
				setBadgeLabel("guntp","🔫 Returned!")
				task.delay(1.5,function() removeBadge("guntp");setGunTp(false) end)
			end
		end
	end

	if fakeSpeedOn then
		local c=getChar(LocalPlayer);if not c then return end
		local h=c:FindFirstChildOfClass("Humanoid");if not h then return end
		if not hasAnyTool(LocalPlayer) then
			h.WalkSpeed=16;setBadgeLabel("speed","🚀 Equip tool!")
		elseif h.FloorMaterial==Enum.Material.Air then
			h.WalkSpeed=FAKE_SPEED;setBadgeLabel("speed","🚀 Boosting!")
		else h.WalkSpeed=16;setBadgeLabel("speed","🚀 Jump!") end
	end
end)

-- ══════════════════════════════════════
--   CLEANUP ON PLAYER LEAVE
-- ══════════════════════════════════════
Players.PlayerRemoving:Connect(function(p)
	removeESP(p)
	if lockedTarget==p then
		murdLockOn=false;lockedTarget=nil;lockMode=nil;stopCamLock();removeBadge("murd")
		mfStatus.Text="Click to lock";murdFloatBtn.BackgroundColor3=Color3.fromRGB(180,35,35)
	end
	if currentSheriff==p then currentSheriff=nil;clearSheriffConn();gunLastPos=nil end
end)

