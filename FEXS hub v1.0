local setList=Instance.new("UIListLayout")
setList.FillDirection=Enum.FillDirection.Vertical;setList.SortOrder=Enum.SortOrder.LayoutOrder
setList.Padding=UDim.new(0,6);setList.Parent=setScroll

local setPad=Instance.new("UIPadding")
setPad.PaddingTop=UDim.new(0,8);setPad.PaddingLeft=UDim.new(0,10)
setPad.PaddingRight=UDim.new(0,10);setPad.PaddingBottom=UDim.new(0,10);setPad.Parent=setScroll

setList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	setScroll.CanvasSize=UDim2.new(0,0,0,setList.AbsoluteContentSize.Y+20)
end)

local settingsOpen=false
settingsBtn.MouseButton1Click:Connect(function()
	settingsOpen=not settingsOpen
