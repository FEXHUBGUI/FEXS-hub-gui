		settingsPanel.Size=UDim2.new(0,SET_W,0,0)
		tw(settingsPanel,{Size=UDim2.new(0,SET_W,0,SET_H)},easeOut)
	end
	settingsBtn.BackgroundColor3=settingsOpen and Color3.fromRGB(60,200,100) or Color3.fromRGB(40,40,80)
end)
setClose.MouseButton1Click:Connect(function()
	settingsOpen=false
