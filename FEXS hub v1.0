-- ══════════════════════════════════════
--         RAIN HUB — WELCOME BANNER
-- ══════════════════════════════════════
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

local bannerGui = Instance.new("ScreenGui")
bannerGui.Name = "RainHubBanner"
bannerGui.ResetOnSpawn = false
bannerGui.IgnoreGuiInset = true
bannerGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
bannerGui.Parent = LocalPlayer.PlayerGui

-- Outer glow backing (slightly wider, sits behind)
local glow = Instance.new("Frame")
glow.Name = "Glow"
glow.AnchorPoint = Vector2.new(0.5, 0)
glow.Size = UDim2.new(0, 520, 0, 64)
glow.Position = UDim2.new(0.5, 0, 0, 14)
glow.BackgroundColor3 = Color3.fromRGB(20, 80, 180)
glow.BackgroundTransparency = 1
glow.BorderSizePixel = 0
glow.ZIndex = 9
glow.Parent = bannerGui

local glowCorner = Instance.new("UICorner")
glowCorner.CornerRadius = UDim.new(0, 16)
glowCorner.Parent = glow

-- Main panel
local panel = Instance.new("Frame")
panel.Name = "Panel"
panel.AnchorPoint = Vector2.new(0.5, 0)
panel.Size = UDim2.new(0, 500, 0, 58)
panel.Position = UDim2.new(0.5, 0, 0, 18)
panel.BackgroundColor3 = Color3.fromRGB(8, 18, 40)
panel.BackgroundTransparency = 1
panel.BorderSizePixel = 0
panel.ZIndex = 10
panel.Parent = bannerGui

local panelCorner = Instance.new("UICorner")
panelCorner.CornerRadius = UDim.new(0, 12)
panelCorner.Parent = panel

local panelStroke = Instance.new("UIStroke")
panelStroke.Color = Color3.fromRGB(40, 130, 255)
panelStroke.Thickness = 2
panelStroke.Transparency = 1
panelStroke.Parent = panel

-- Animated rain gradient bar at top of panel
local accentBar = Instance.new("Frame")
accentBar.Size = UDim2.new(1, 0, 0, 3)
accentBar.Position = UDim2.new(0, 0, 0, 0)
accentBar.BackgroundColor3 = Color3.fromRGB(60, 160, 255)
accentBar.BackgroundTransparency = 1
accentBar.BorderSizePixel = 0
accentBar.ZIndex = 11
accentBar.Parent = panel

local accentCorner = Instance.new("UICorner")
accentCorner.CornerRadius = UDim.new(0, 12)
accentCorner.Parent = accentBar

-- Gradient on accent bar
local grad = Instance.new("UIGradient")
grad.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0,   Color3.fromRGB(20,  100, 220)),
	ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 180, 255)),
	ColorSequenceKeypoint.new(1,   Color3.fromRGB(20,  100, 220)),
})
grad.Parent = accentBar

-- Rain drop icon label
local icon = Instance.new("TextLabel")
icon.Size = UDim2.new(0, 36, 0, 36)
icon.Position = UDim2.new(0, 12, 0.5, -18)
icon.BackgroundTransparency = 1
icon.Text = "🌧️"
icon.TextSize = 22
icon.Font = Enum.Font.GothamBold
icon.ZIndex = 12
icon.Parent = panel

-- Main text
local mainText = Instance.new("TextLabel")
mainText.Size = UDim2.new(1, -56, 0, 24)
mainText.Position = UDim2.new(0, 50, 0, 8)
mainText.BackgroundTransparency = 1
mainText.Text = "Welcome to Rain Hub!  ENJOY!"
mainText.TextColor3 = Color3.fromRGB(160, 210, 255)
mainText.TextSize = 16
mainText.Font = Enum.Font.GothamBold
mainText.TextXAlignment = Enum.TextXAlignment.Left
mainText.TextTransparency = 1
mainText.ZIndex = 12
mainText.Parent = panel

-- Sub text
local subText = Instance.new("TextLabel")
subText.Size = UDim2.new(1, -56, 0, 16)
subText.Position = UDim2.new(0, 50, 0, 32)
subText.BackgroundTransparency = 1
subText.Text = "⚡ WE UPDATE ALMOST EVERYDAY!"
subText.TextColor3 = Color3.fromRGB(80, 160, 255)
subText.TextSize = 11
subText.Font = Enum.Font.Gotham
subText.TextXAlignment = Enum.TextXAlignment.Left
subText.TextTransparency = 1
subText.ZIndex = 12
subText.Parent = panel

-- ── ANIMATE IN ──
local easeIn = TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local easeOut = TweenInfo.new(0.6, Enum.EasingStyle.Quint, Enum.EasingDirection.In)

local function tweenProps(obj, props, info)
	TweenService:Create(obj, info, props):Play()
end

-- Fade + slide in
local function playFadeIn()
	-- Panel slides down from slightly above
	panel.Position = UDim2.new(0.5, 0, 0, -10)
	glow.Position  = UDim2.new(0.5, 0, 0, -6)

	tweenProps(panel,      {BackgroundTransparency = 0,    Position = UDim2.new(0.5, 0, 0, 18)}, easeIn)
	tweenProps(glow,       {BackgroundTransparency = 0.75, Position = UDim2.new(0.5, 0, 0, 14)}, easeIn)
	tweenProps(panelStroke,{Transparency = 0}, easeIn)
	tweenProps(accentBar,  {BackgroundTransparency = 0}, easeIn)
	tweenProps(mainText,   {TextTransparency = 0}, easeIn)
	tweenProps(subText,    {TextTransparency = 0}, easeIn)
end

local function playFadeOut()
	tweenProps(panel,      {BackgroundTransparency = 1,    Position = UDim2.new(0.5, 0, 0, -10)}, easeOut)
	tweenProps(glow,       {BackgroundTransparency = 1,    Position = UDim2.new(0.5, 0, 0, -6)},  easeOut)
	tweenProps(panelStroke,{Transparency = 1}, easeOut)
	tweenProps(accentBar,  {BackgroundTransparency = 1}, easeOut)
	tweenProps(mainText,   {TextTransparency = 1}, easeOut)
	tweenProps(subText,    {TextTransparency = 1}, easeOut)
end

-- Shimmer loop on accent bar gradient
local shimmerAngle = 0
local shimmerConn
shimmerConn = game:GetService("RunService").Heartbeat:Connect(function(dt)
	shimmerAngle = (shimmerAngle + dt * 60) % 360
	grad.Rotation = shimmerAngle
end)

-- Sequence: wait a tick, fade in, hold 3s, fade out, cleanup
task.spawn(function()
	task.wait(0.3)
	playFadeIn()
	task.wait(3.8) -- hold time (accounts for fade-in duration)
	playFadeOut()
	task.wait(0.9)
	shimmerConn:Disconnect()
	bannerGui:Destroy()
end)
