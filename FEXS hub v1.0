-- Function to switch tabs with animation
local currentTab = tradeFrame
local function switchTab(newTab)
    local tweenOut = TweenService:Create(currentTab, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Position = UDim2.new(-1, 0, 0.2, 0)})
    tweenOut:Play()
    tweenOut.Completed:Wait()
    currentTab.Visible = false
    currentTab.Position = UDim2.new(1, 0, 0.2, 0)
    newTab.Position = UDim2.new(1, 0, 0.2, 0)
    newTab.Visible = true
    local tweenIn = TweenService:Create(newTab, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Position = UDim2.new(0, 0, 0.2, 0)})
    tweenIn:Play()
    currentTab = newTab
end

tradeBtn.MouseButton1Click:Connect(function()
    if currentTab ~= tradeFrame then
        switchTab(tradeFrame)
    end
end)

valuesBtn.MouseButton1Click:Connect(function()
    if currentTab ~= valuesFrame then
        switchTab(valuesFrame)
    end
end)

