--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "RainHubMM2"

-- SIDE TOGGLE BUTTON
local toggleBtn = Instance.new("TextButton", gui)
toggleBtn.Size = UDim2.new(0,30,0,70)
toggleBtn.Position = UDim2.new(0,0,0.4,0)
toggleBtn.Text = "≡"
toggleBtn.Font = Enum.Font.Arcade
toggleBtn.BackgroundColor3 = Color3.fromRGB(0,120,255)
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.Draggable = true
Instance.new("UICorner", toggleBtn)

-- MAIN (SMALLER + CENTERED)
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,300,0,260)
main.Position = UDim2.new(0.5,-150,0.5,-130)
main.BackgroundColor3 = Color3.fromRGB(10,15,25)
main.Visible = false
main.Active = true
main.Draggable = true
Instance.new("UICorner", main)

-- TITLE
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Rain Hub MM2"
title.Font = Enum.Font.Arcade
title.TextColor3 = Color3.fromRGB(0,170,255)
title.BackgroundTransparency = 1

-- WATER EFFECT
local water = Instance.new("Frame", main)
water.Size = UDim2.new(1,0,1,0)
water.BackgroundTransparency = 0.8
water.BackgroundColor3 = Color3.fromRGB(0,80,150)

task.spawn(function()
	while true do
		TweenService:Create(water,TweenInfo.new(3),{BackgroundTransparency = 0.85}):Play()
		task.wait(3)
		TweenService:Create(water,TweenInfo.new(3),{BackgroundTransparency = 0.75}):Play()
		task.wait(3)
	end
end)

-- RAIN
for i = 1,20 do
	local drop = Instance.new("ImageLabel", main)
	drop.Image = "rbxassetid://133078236"
	drop.Size = UDim2.new(0,8,0,20)
	drop.BackgroundTransparency = 1
	
	task.spawn(function()
		while true do
			drop.Position = UDim2.new(math.random(),0,-0.2,0)
			local t = TweenService:Create(drop,TweenInfo.new(1.3,Enum.EasingStyle.Linear),{
				Position = UDim2.new(drop.Position.X.Scale,0,1.2,0)
			})
			t:Play()
			t.Completed:Wait()
		end
	end)
end

-- TABS
local tabHolder = Instance.new("Frame", main)
tabHolder.Size = UDim2.new(1,0,0,25)
tabHolder.Position = UDim2.new(0,0,0,30)

local content = Instance.new("Frame", main)
content.Size = UDim2.new(1,0,1,-55)
content.Position = UDim2.new(0,0,0,55)

local tabs = {"Murderer","Sheriff","Visual"}
local tabFrames = {}

for i,name in pairs(tabs) do
	local btn = Instance.new("TextButton", tabHolder)
	btn.Size = UDim2.new(1/#tabs,0,1,0)
	btn.Position = UDim2.new((i-1)/#tabs,0,0,0)
	btn.Text = name
	btn.Font = Enum.Font.Arcade
	btn.BackgroundColor3 = Color3.fromRGB(20,25,40)
	btn.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", btn)

	local frame = Instance.new("Frame", content)
	frame.Size = UDim2.new(1,0,1,0)
	frame.Visible = false

	tabFrames[name] = frame

	btn.MouseButton1Click:Connect(function()
		for _,f in pairs(tabFrames) do f.Visible = false end
		frame.Visible = true
	end)
end

tabFrames["Visual"].Visible = true

-- BUTTON CREATOR
function makeBtn(parent,text,y,color,callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.85,0,0,35)
	b.Position = UDim2.new(0.075,0,0,y)
	b.Text = text.." [OFF]"
	b.Font = Enum.Font.Arcade
	b.BackgroundColor3 = Color3.fromRGB(15,15,25)
	b.TextColor3 = Color3.new(1,1,1)

	local stroke = Instance.new("UIStroke", b)
	stroke.Color = color
	stroke.Thickness = 2

	Instance.new("UICorner", b)

	local state = false

	b.MouseButton1Click:Connect(function()
		state = not state
		b.Text = text.." ["..(state and "ON" or "OFF").."]"
		callback(state)
	end)
end

-- ESP
local espOn = false

RunService.RenderStepped:Connect(function()
	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			local char = p.Character

			if char:FindFirstChild("Highlight") then
				char.Highlight:Destroy()
			end

			if espOn then
				local h = Instance.new("Highlight", char)

				if p:FindFirstChild("Backpack") and (p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")) then
					h.FillColor = Color3.fromRGB(255,0,0)
				elseif p:FindFirstChild("Backpack") and (p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")) then
					h.FillColor = Color3.fromRGB(0,150,255)
				else
					h.FillColor = Color3.fromRGB(0,255,0)
				end
			end
		end
	end
end)

-- VISUAL TAB
makeBtn(tabFrames["Visual"],"ESP",10,Color3.fromRGB(0,150,255),function(v)
	espOn = v
end)

-- POTATO
makeBtn(tabFrames["Visual"],"Potato Mode",55,Color3.fromRGB(150,150,150),function(v)
	Lighting.GlobalShadows = not v
	for _,d in pairs(workspace:GetDescendants()) do
		if d:IsA("Texture") or d:IsA("Decal") then
			d:Destroy()
		end
	end
end)

-- GLOSSY (FIXED)
makeBtn(tabFrames["Visual"],"Glossy Shader",100,Color3.fromRGB(0,200,255),function(v)
	for _,p in pairs(workspace:GetDescendants()) do
		if p:IsA("BasePart") then
			p.Material = v and Enum.Material.SmoothPlastic or Enum.Material.Plastic
			p.Reflectance = v and 0.5 or 0
		end
	end
end)

-- LOCK BUTTON UI
local lockBtn = Instance.new("TextButton", gui)
lockBtn.Size = UDim2.new(0,120,0,45)
lockBtn.Position = UDim2.new(0.5,-60,0.8,0)
lockBtn.Visible = false
lockBtn.Font = Enum.Font.Arcade
lockBtn.TextColor3 = Color3.new(1,1,1)
lockBtn.BackgroundTransparency = 0.2
lockBtn.Draggable = true
Instance.new("UICorner", lockBtn)

local locking = false
local mode = nil

lockBtn.MouseButton1Click:Connect(function()
	locking = not locking
end)

function getTarget()
	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			if mode == "Murderer" then
				if p.Backpack:FindFirstChild("Knife") or (p.Character and p.Character:FindFirstChild("Knife")) then
					return p
				end
			elseif mode == "Sheriff" then
				if p.Backpack:FindFirstChild("Gun") or (p.Character and p.Character:FindFirstChild("Gun")) then
					return p
				end
			end
		end
	end
end

RunService.RenderStepped:Connect(function()
	if locking then
		local target = getTarget()
		if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
			local pos = target.Character.HumanoidRootPart.Position
			workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame:Lerp(
				CFrame.new(workspace.CurrentCamera.CFrame.Position, pos),
				0.2
			)
		end
	end
end)

-- MURDERER TAB
makeBtn(tabFrames["Murderer"],"Lock Sheriff Button",10,Color3.fromRGB(0,150,255),function(v)
	lockBtn.Visible = v
	mode = "Sheriff"
	lockBtn.Text = "Lock Sheriff"
	lockBtn.BackgroundColor3 = Color3.fromRGB(0,100,255)
end)

-- SHERIFF TAB
makeBtn(tabFrames["Sheriff"],"Lock Murderer Button",10,Color3.fromRGB(255,50,50),function(v)
	lockBtn.Visible = v
	mode = "Murderer"
	lockBtn.Text = "Lock Murderer"
	lockBtn.BackgroundColor3 = Color3.fromRGB(200,50,50)
end)

-- OPEN/CLOSE GUI
local open = false

toggleBtn.MouseButton1Click:Connect(function()
	open = not open
	main.Visible = open
end)
