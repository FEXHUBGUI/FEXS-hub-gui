-- ── SETTINGS ROW HELPERS ──────────────
local setRowOrder=0

local function makeSetSection(title)
	setRowOrder+=1
	local f=Instance.new("Frame")
	f.Size=UDim2.new(1,0,0,24);f.BackgroundTransparency=1
	f.LayoutOrder=setRowOrder;f.ZIndex=52;f.Parent=setScroll
	local l=Instance.new("TextLabel");l.Size=UDim2.new(1,0,1,0)
	l.BackgroundTransparency=1;l.Text=title
	l.TextColor3=cfgC3("hubAccent");l.TextSize=11;l.Font=Enum.Font.GothamBold
	l.TextXAlignment=Enum.TextXAlignment.Left;l.ZIndex=53;l.Parent=f
end

local function makeSlider(label, minV, maxV, initV, fmt, onChange)
	setRowOrder+=1
	local ROW_H=52
	local row=Instance.new("Frame")
	row.Size=UDim2.new(1,0,0,ROW_H);row.BackgroundColor3=Color3.fromRGB(13,26,62)
	row.BorderSizePixel=0;row.LayoutOrder=setRowOrder;row.ZIndex=52;row.Parent=setScroll
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)

	local lbl=Instance.new("TextLabel")
	lbl.Size=UDim2.new(1,-70,0,20);lbl.Position=UDim2.new(0,10,0,6)
	lbl.BackgroundTransparency=1;lbl.Text=label
	lbl.TextColor3=Color3.fromRGB(200,220,255);lbl.TextSize=11;lbl.Font=Enum.Font.GothamBold
	lbl.TextXAlignment=Enum.TextXAlignment.Left;lbl.ZIndex=53;lbl.Parent=row

	local valLbl=Instance.new("TextLabel")
	valLbl.Size=UDim2.new(0,60,0,20);valLbl.Position=UDim2.new(1,-68,0,6)
	valLbl.BackgroundTransparency=1;valLbl.TextColor3=cfgC3("hubAccent")
	valLbl.TextSize=11;valLbl.Font=Enum.Font.GothamBold
	valLbl.TextXAlignment=Enum.TextXAlignment.Right;valLbl.ZIndex=53;valLbl.Parent=row

	local track=Instance.new("Frame")
	track.Size=UDim2.new(1,-20,0,6);track.Position=UDim2.new(0,10,0,34)
	track.BackgroundColor3=Color3.fromRGB(30,35,60);track.BorderSizePixel=0
	track.ZIndex=53;track.Parent=row
	Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)

	local fill=Instance.new("Frame")
	fill.Size=UDim2.new((initV-minV)/(maxV-minV),0,1,0)
	fill.BackgroundColor3=cfgC3("hubAccent");fill.BorderSizePixel=0
	fill.ZIndex=54;fill.Parent=track
	Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)

	local knob=Instance.new("Frame")
	knob.Size=UDim2.new(0,14,0,14);knob.AnchorPoint=Vector2.new(0.5,0.5)
	knob.Position=UDim2.new((initV-minV)/(maxV-minV),0,0.5,0)
	knob.BackgroundColor3=Color3.new(1,1,1);knob.BorderSizePixel=0
	knob.ZIndex=55;knob.Parent=track
	Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

	local curVal=initV
	valLbl.Text=string.format(fmt,curVal)

	local sliding=false
	local function setVal(px)
		local rel=math.clamp((px-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
		curVal=math.floor((minV+(maxV-minV)*rel)*100+0.5)/100
		if math.floor(minV)==minV and math.floor(maxV)==maxV then
			curVal=math.floor(curVal+0.5)
		end
		valLbl.Text=string.format(fmt,curVal)
		fill.Size=UDim2.new(rel,0,1,0)
		knob.Position=UDim2.new(rel,0,0.5,0)
		if onChange then onChange(curVal) end
	end

	local sliderBtn=Instance.new("TextButton")
	sliderBtn.Size=UDim2.new(1,0,1,0);sliderBtn.BackgroundTransparency=1
	sliderBtn.Text="";sliderBtn.ZIndex=56;sliderBtn.Parent=track
	sliderBtn.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			sliding=true;setVal(inp.Position.X)
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if not sliding then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement
		or inp.UserInputType==Enum.UserInputType.Touch then
			setVal(inp.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			sliding=false
		end
	end)
end

local function makeSetToggle(label, initVal, onChange)
	setRowOrder+=1
	local row=Instance.new("Frame")
	row.Size=UDim2.new(1,0,0,40);row.BackgroundColor3=Color3.fromRGB(13,26,62)
	row.BorderSizePixel=0;row.LayoutOrder=setRowOrder;row.ZIndex=52;row.Parent=setScroll
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)

	local lbl=Instance.new("TextLabel")
	lbl.Size=UDim2.new(1,-60,1,0);lbl.Position=UDim2.new(0,10,0,0)
	lbl.BackgroundTransparency=1;lbl.Text=label
	lbl.TextColor3=Color3.fromRGB(200,220,255);lbl.TextSize=11;lbl.Font=Enum.Font.GothamBold
	lbl.TextXAlignment=Enum.TextXAlignment.Left;lbl.ZIndex=53;lbl.Parent=row

	local pillBg=Instance.new("Frame")
	pillBg.Size=UDim2.new(0,40,0,20);pillBg.Position=UDim2.new(1,-48,0.5,-10)
	pillBg.BackgroundColor3=initVal and Color3.fromRGB(40,200,100) or Color3.fromRGB(55,60,82)
	pillBg.BorderSizePixel=0;pillBg.ZIndex=53;pillBg.Parent=row
	Instance.new("UICorner",pillBg).CornerRadius=UDim.new(1,0)

	local knob=Instance.new("Frame")
	knob.Size=UDim2.new(0,16,0,16)
	knob.Position=initVal and UDim2.new(0,21,0.5,-8) or UDim2.new(0,3,0.5,-8)
	knob.BackgroundColor3=Color3.new(1,1,1);knob.BorderSizePixel=0
	knob.ZIndex=54;knob.Parent=pillBg
	Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

	local isOn=initVal
	local btn=Instance.new("TextButton")
	btn.Size=UDim2.new(1,0,1,0);btn.BackgroundTransparency=1
	btn.Text="";btn.ZIndex=55;btn.Parent=row
	btn.MouseButton1Click:Connect(function()
		isOn=not isOn
		tw(pillBg,{BackgroundColor3=isOn and Color3.fromRGB(40,200,100) or Color3.fromRGB(55,60,82)},fastTw)
		tw(knob,{Position=isOn and UDim2.new(0,21,0.5,-8) or UDim2.new(0,3,0.5,-8)},fastTw)
		if onChange then onChange(isOn) end
	end)
end

