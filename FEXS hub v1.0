-- ══════════════════════════════════════
--   TWEEN SHORTHAND
-- ══════════════════════════════════════
local function tw(obj, props, info)
	TweenService:Create(obj, info, props):Play()
end
local easeOut = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local easeIn  = TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
local fastTw  = TweenInfo.new(0.18, Enum.EasingStyle.Quad,  Enum.EasingDirection.Out)

