-- Lists for offers
local yourItems = {}
local theirItems = {}

-- Function to update totals
local function updateYourTotal()
    local total = 0
    for _, val in ipairs(yourItems) do
        total = total + val
    end
    yourTotal.Text = "Total: " .. total
    return total
end

local function updateTheirTotal()
    local total = 0
    for _, val in ipairs(theirItems) do
        total = total + val
    end
    theirTotal.Text = "Total: " .. total
    return total
end

-- Add to your offer
yourAddBtn.MouseButton1Click:Connect(function()
    local itemName = yourInput.Text:lower():gsub("'", "")
    local data = values[itemName]
    if data then
        table.insert(yourItems, data.value)
        local itemLabel = Instance.new("TextLabel")
        itemLabel.Size = UDim2.new(0.8, 0, 0, 30)
        itemLabel.BackgroundTransparency = 1
        itemLabel.Text = data.name .. ": " .. data.value
        itemLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        itemLabel.TextSize = 14
        itemLabel.Parent = yourList
        
        local removeBtn = Instance.new("TextButton")
        removeBtn.Size = UDim2.new(0.2, 0, 1, 0)
        removeBtn.Position = UDim2.new(0.8, 0, 0, 0)
        removeBtn.BackgroundTransparency = 1
        removeBtn.Text = "X"
        removeBtn.TextColor3 = Color3.fromRGB(255, 0, 0)
        removeBtn.Parent = itemLabel
        removeBtn.MouseButton1Click:Connect(function()
            for i, v in ipairs(yourItems) do
                if v == data.value then
                    table.remove(yourItems, i)
                    break
                end
            end
            itemLabel:Destroy()
            updateYourTotal()
            yourList.CanvasSize = UDim2.new(0, 0, 0, #yourList:GetChildren() * 35 - 35)
        end)
        
        yourList.CanvasSize = UDim2.new(0, 0, 0, (#yourList:GetChildren() - 1) * 35)
        updateYourTotal()
        yourInput.Text = ""
    else
        StarterGui:SetCore("SendNotification", {Title = "Error", Text = "Item not found!", Duration = 3})
    end
end)

-- Add to their offer (similar)
theirAddBtn.MouseButton1Click:Connect(function()
    local itemName = theirInput.Text:lower():gsub("'", "")
    local data = values[itemName]
    if data then
        table.insert(theirItems, data.value)
        local itemLabel = Instance.new("TextLabel")
        itemLabel.Size = UDim2.new(0.8, 0, 0, 30)
